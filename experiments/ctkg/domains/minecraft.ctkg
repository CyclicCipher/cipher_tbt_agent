-- minecraft.ctkg — Minecraft domain for the MineDojo experiment
--
-- Phase A skeleton: types + motor priors + observation concepts +
-- early achievement DAG.
--
-- Architecture
-- ------------
-- Layer 0  Motor priors — effectful action primitives (mc_attack, mc_forward,
--          etc.).  Like succ/pred in arithmetic: atomic, unlearnable, directly
--          wired to the game API via MinecraftModality.
--
-- Layer 1  Observation concepts — pure reads of game state (mc_health,
--          mc_food, etc.).  Also atomic; the agent gets these for free.
--
-- Layer 2  Perceptual concepts — learned via approximate visual synthesis
--          (log_detection, entity_detection, block_color_signature).
--          No processes declared here; the agent discovers them.
--
-- Layer 3  World knowledge — learned via causal synthesis
--          (break_log, obtain_log, craft_planks, ...).
--          No processes declared; synthesized from experience.
--
-- Layer 4  Achievement DAG — Minecraft's advancement tree.
--          Nodes = achievement milestones.
--          Edges (requires) = epistemic ordering only.
--          No processes; the agent learns how to reach each achievement.
--
-- Edge types used in this file (Phase B):
--   requires       — epistemic ordering (what the agent must know first)
--   causes         — physical causation with optional guard/delay/probability
--   composes_into  — multi-input crafting/composition (product morphism)
--   instance_of    — subtype hierarchy (induces analogy spans)
--   precedes       — temporal ordering (action sequencing)
--
-- Observation constraints
-- -----------------------
-- We do NOT use MineDojo's 'biome' field or 'nearby_entities' field.
-- Biomes must be learned as visual clusters (pixel distributions).
-- Entities must be detected from frame difference, not labeled APIs.
-- See MINEDOJO.md "Observation Constraints" for rationale.

interface minecraft_domain
  exports types mc_frame item_count angle_deg time_ticks binary slot_index step_count
  exports types feature_map saliency_map gaze_point
  exports concepts observe_rgb observe_health observe_food observe_inventory
  exports concepts observe_position observe_time observe_is_night
  exports concepts motor_forward motor_back motor_attack motor_use motor_jump
  exports concepts v1_encode v1_saliency v1_next_gaze v1_foveal_mean v1_foveal_std
  exports concepts prior_light_above prior_looming prior_figure_ground prior_object_permanence
  exports concepts texture_patch block_face block_type
  exports concepts log_detection break_log obtain_log
  exports concepts achieve_getting_wood achieve_benchmarking achieve_time_to_mine

-- ===========================================================================
-- Types
-- ===========================================================================

-- Primary percept: the camera frame from obs['rgb']
type mc_frame     = seq(tuple(nat, nat, nat) ordered) ordered

-- Inventory quantity (0 to max stack size, e.g. 64)
type item_count   = nat metric

-- Camera angle in degrees
type angle_deg    = nat ordered

-- Minecraft in-game time (0–24000 ticks per day)
type time_ticks   = nat metric

-- Number of game ticks / steps
type step_count   = nat metric

-- Hotbar slot index (0–8)
type slot_index   = symbol(0, 1, 2, 3, 4, 5, 6, 7, 8)

-- Boolean result (0 = false, 1 = true)
type binary       = symbol(0, 1)

-- Retinotopic feature map: (n_rings × n_angles × 16 Gabor channels) float32
-- Output of VisualCortex.encode().  Fixed architecture; not learned.
type feature_map  = seq(seq(nat ordered) ordered) ordered

-- Pixel-space attention map: (H × W) float32 saliency weights
-- Output of VisualCortex.saliency().
type saliency_map = seq(seq(nat ordered) ordered) ordered

-- Gaze point: (y, x) integer pixel coordinates for eye movement targeting
type gaze_point   = tuple(nat, nat) ordered

-- ===========================================================================
-- Layer 0: Motor priors (effectful action primitives)
--
-- These are the 'succ'/'pred' of the Minecraft domain — atomic motor
-- capabilities that the agent has by instinct.  The process expressions
-- are trivial wrappers around mc_ primitives from MinecraftModality.
--
-- In synthesis mode these primitives raise DryRunError (Phase D).
-- In execution mode they send commands to the live MineDojo env.
-- ===========================================================================

concept motor_forward
  domain minecraft
  description "Walk forward n game ticks; returns final (x,y,z) position"
  input step_count
  output mc_frame
  process emit(mc_forward(a))

concept motor_back
  domain minecraft
  description "Walk backward n game ticks; returns final (x,y,z) position"
  input step_count
  output mc_frame
  process emit(mc_back(a))

concept motor_left
  domain minecraft
  description "Strafe left n game ticks; returns final (x,y,z) position"
  input step_count
  output mc_frame
  process emit(mc_left(a))

concept motor_right
  domain minecraft
  description "Strafe right n game ticks; returns final (x,y,z) position"
  input step_count
  output mc_frame
  process emit(mc_right(a))

concept motor_turn
  domain minecraft
  description "Rotate camera (yaw_delta, pitch_delta degrees); returns (yaw, pitch)"
  input angle_deg angle_deg
  output angle_deg
  process emit(mc_turn(a, b))

concept motor_jump
  domain minecraft
  description "Jump once; returns 1"
  output binary
  process emit(mc_jump())

concept motor_attack
  domain minecraft
  description "Execute one attack or block-break tick; returns 1"
  output binary
  process emit(mc_attack())

concept motor_use
  domain minecraft
  description "Execute one use/right-click/place tick; returns 1"
  output binary
  process emit(mc_use())

concept motor_sprint
  domain minecraft
  description "Enable (1) or disable (0) sprinting; returns new state"
  input binary
  output binary
  process emit(mc_sprint(a))

concept motor_sneak
  domain minecraft
  description "Enable (1) or disable (0) sneaking; returns new state"
  input binary
  output binary
  process emit(mc_sneak(a))

concept motor_select
  domain minecraft
  description "Select hotbar slot n (0–8); returns selected slot"
  input slot_index
  output slot_index
  process emit(mc_select_slot(a))

concept motor_drop
  domain minecraft
  description "Drop currently held item; returns 1"
  output binary
  process emit(mc_drop())

-- ===========================================================================
-- Layer 1: Observation concepts (pure reads — not learned)
--
-- The agent gets these observation channels for free.  The process
-- expressions simply call the corresponding mc_ primitive from
-- MinecraftModality.  No MineDojo-prohibited fields are used.
-- ===========================================================================

concept observe_rgb
  domain minecraft
  description "Current camera frame as H×W×3 float32 array"
  output mc_frame
  process emit(mc_rgb())

concept observe_health
  domain minecraft
  description "Current HP (0–20); feeds U_pain drive"
  output item_count
  process emit(mc_health())

concept observe_food
  domain minecraft
  description "Current food level (0–20); feeds U_hunger drive"
  output item_count
  process emit(mc_food())

concept observe_inventory
  domain minecraft
  description "Count of a named item in the inventory"
  input item_count
  output item_count
  process emit(mc_inventory(a))

concept observe_position
  domain minecraft
  description "Current XYZ position as (x,y,z) float triple"
  process emit(mc_position())

concept observe_yaw
  domain minecraft
  description "Current head yaw in degrees"
  output angle_deg
  process emit(mc_yaw())

concept observe_pitch
  domain minecraft
  description "Current head pitch in degrees"
  output angle_deg
  process emit(mc_pitch())

concept observe_time
  domain minecraft
  description "In-game time (0–24000 ticks); feeds U_sleep drive"
  output time_ticks
  process emit(mc_time_of_day())

concept observe_is_night
  domain minecraft
  description "1 if it is night (ticks 13000–23000), 0 otherwise"
  output binary
  requires observe_time via "reads the same clock"
  process emit(mc_is_night())

concept observe_frame_diff
  domain minecraft
  description "Absolute frame difference; detects motion (entities, drops)"
  output mc_frame
  requires observe_rgb via "requires two consecutive frames" [0.95]
  process emit(mc_frame_diff())

concept observe_frame_std
  domain minecraft
  description "Pixel std over frame buffer; high = persistent motion"
  output mc_frame
  requires observe_frame_diff via "accumulates over K frames" [0.90]
  process emit(mc_frame_std())

-- ===========================================================================
-- Layer 1.5: V1 visual primitives (VisualCortex wrappers — fixed, not learned)
--
-- These are direct wrappers around the VisualCortex methods in
-- MinecraftModality.  Like motor priors and observation concepts, they
-- are atomic — the agent has them by construction.  They are the
-- break point: everything above here is learned knowledge (CTKG).
-- Everything below here is fixed V1 architecture (VisualCortex class).
--
-- Gabor bank: 4 orientations × 4 scales = 16 channels.
-- Log-polar sampling: n_rings=32, n_angles=64, gaze centered at crosshair.
-- These constants are not CTKG knowledge — they are silicon, not synapse.
-- ===========================================================================

concept v1_encode
  domain minecraft
  description "Encode current frame as log-polar Gabor feature map (n_rings,n_angles,16)"
  input mc_frame
  output feature_map
  process emit(vc_encode(a))

concept v1_saliency
  domain minecraft
  description "Bottom-up saliency map: DoG edges + motion from frame buffer"
  input mc_frame
  output saliency_map
  requires observe_rgb via "needs current frame"
  process emit(vc_saliency(a))

concept v1_saliency_hue
  domain minecraft
  description "Goal-directed saliency: bottom-up edges weighted by hue match"
  input mc_frame
  output saliency_map
  requires v1_saliency via "extends bottom-up saliency with top-down hue bias"
  process emit(vc_saliency_hue(a, b))

concept v1_next_gaze
  domain minecraft
  description "Next gaze target (y,x) from saliency map argmax"
  input saliency_map
  output gaze_point
  requires v1_saliency via "saliency map must be computed first"
  process emit(vc_next_gaze(a))

concept v1_foveal_mean
  domain minecraft
  description "Mean activation in foveal (innermost) rings of feature map"
  input feature_map
  output item_count
  requires v1_encode via "feature map must be computed first"
  process emit(vc_foveal_mean(a))

concept v1_foveal_std
  domain minecraft
  description "Std deviation in foveal rings — high = texture-rich fixation"
  input feature_map
  output item_count
  requires v1_encode via "feature map must be computed first"
  process emit(vc_foveal_std(a))

-- ===========================================================================
-- Layer 0.75: Innate visual priors (hardwired, not learned)
--
-- These correspond to the "core knowledge" that developmental psychology
-- has identified as present at birth or within the first weeks of life.
-- They encode structural regularities of the physical world that are
-- stable enough to be built in rather than learned from experience.
--
-- Each prior has a hardcoded process that computes a scalar or boolean
-- signal from raw frames.  The signal is used by the learned hierarchy
-- above (block_face, block_type, entity_detection) as prerequisite input.
--
-- References:
--   prior_light_above    — Ramachandran (1988), infants assume light-from-above
--   prior_looming        — Gibson (1950); Bower (1977) neonatal avoidance response
--   prior_figure_ground  — Rubin (1915); Fantz (1961) infant preference for contour
--   prior_object_permanence — Baillargeon (1987) 3.5-month-olds; Spelke core knowledge
-- ===========================================================================

concept prior_light_above
  domain minecraft
  description "Top face of block is brighter than bottom (sun is above; Ramachandran 1988)"
  input mc_frame
  requires v1_encode via "V1 features encode local brightness for confirmation"
  -- Returns: float brightness gradient (top_quarter_mean - bottom_quarter_mean).
  -- Positive = surface lit from above = top face of block.
  -- Used by block_face to infer 3D orientation from a single frame.
  process
    bgrad = vc_brightness_gradient(a)
    emit(bgrad)

concept prior_looming
  domain minecraft
  description "Approaching surface: center motion > peripheral motion (Gibson 1950; Bower 1977)"
  input mc_frame
  requires observe_frame_diff via "frame difference signal required for motion" [0.95]
  -- Returns: float looming score (center_diff_mean - full_frame_diff_mean).
  -- Positive = approaching surface → obstacle, wall, or entity coming close.
  -- Used by the navigation policy to brake / turn before collision.
  process
    loom = vc_looming(a)
    emit(loom)

concept prior_figure_ground
  domain minecraft
  description "Sky = background; blocks = figure (Rubin 1915; large surrounding = ground)"
  input mc_frame
  requires v1_saliency via "edge map confirms figure boundaries" [0.80]
  -- Returns: float in [0, 1] — fraction of top strip matching Minecraft sky hue.
  -- 0.0 = cave / interior; 1.0 = open outdoor environment.
  -- Used as context signal: outdoor → daylight priors apply;
  --                         indoor/cave → looming signals more informative.
  process
    sky = vc_sky_fraction(a)
    emit(sky)

concept prior_object_permanence
  domain minecraft
  description "Blocks persist when not observed; world state is stable between steps (Baillargeon 1987)"
  requires observe_rgb        via "requires camera to have observed blocks"
  requires observe_position   via "position gives coordinate frame for persistence"
  -- No process: this is a world-model constraint, not a computation.
  -- It asserts that a block seen at (x,y,z) will be there on re-observation
  -- unless a break_log / destroy event occurred.
  -- Consequence: the agent does not need to re-verify every visible block
  -- each step — it can cache observations and trust they persist.
  -- Implemented in agent_loop.py via the observation cache in EligibilityTrace.

-- ===========================================================================
-- Layer 2a: Visual hierarchy (V2 → V4 → IT analog — learned)
--
-- This IS where CTKG belongs.  Each level is a learnable concept:
--
--   v1_encode (fixed)
--       ↓ requires
--   texture_patch  — V2 analog: group Gabor responses into texture classes
--       ↓ requires
--   block_face     — V4 analog: coherent flat surface from texture regularity
--       ↓ requires
--   block_type     — IT analog: semantic label (log, stone, grass, ...)
--
-- The prerequisite chain IS the V2→IT hierarchy.  Active gaze (v1_next_gaze
-- → motor_turn) provides position invariance so global spatial pooling is
-- not needed.  The hierarchy is traversed in foveal coordinates.
--
-- No processes declared: the agent synthesizes these via template search
-- over vc_* primitives after accumulating labelled (frame, label) examples.
-- ===========================================================================

concept texture_patch
  domain minecraft
  description "Classify texture of the foveated patch (smooth/rough/organic/stone/wood)"
  requires v1_encode    via "Gabor feature map provides texture signature"
  requires v1_foveal_std via "high foveal std = textured surface; low = sky/water"

concept block_face
  domain minecraft
  description "Detect a coherent flat block face at gaze point (Minecraft blocks are voxels)"
  requires texture_patch       via "texture regularity is the primary cue for flat faces"
  requires v1_foveal_mean      via "uniform mean across fovea confirms flatness"
  requires prior_light_above   via "brightness gradient reveals face orientation (top vs side)" [0.85]
  requires prior_figure_ground via "outdoor context activates daylight shading priors" [0.70]

concept block_type
  domain minecraft
  description "Identify semantic block type at gaze (log, stone, grass, dirt, ...)"
  requires block_face    via "face must be detected before type can be assigned"
  requires v1_encode     via "full feature map needed for fine-grained classification"

-- ===========================================================================
-- Layer 2: Perceptual concepts (learned from visual experience)
--
-- No processes: the agent synthesizes these via approximate synthesis
-- (consolidate_approx) after accumulating enough visual examples.
-- ===========================================================================

concept log_detection
  domain minecraft
  description "Detect a log block in the current camera frame"
  requires block_type         via "semantic block identity resolves log vs non-log" [0.90]
  requires observe_rgb        via "provides camera access"
  requires observe_frame_diff via "helps distinguish log from background" [0.70]

concept block_color_signature
  domain minecraft
  description "Classify block type from color distribution of a camera patch"
  requires observe_rgb    via "provides image data"
  requires log_detection  via "bootstraps from known block template" [0.60]

concept entity_detection
  domain minecraft
  description "Detect a moving entity from frame difference"
  requires observe_frame_diff via "primary signal for entity motion" [0.90]
  requires observe_frame_std  via "filters persistent vs transient motion" [0.75]

-- ===========================================================================
-- Layer 3: World knowledge (learned via causal synthesis)
--
-- No processes: the agent discovers these by observing
-- (observation, action, observation) triples and synthesizing rules
-- that predict what happens when actions are taken.
-- ===========================================================================

concept break_log
  domain minecraft
  description "Break a log block by holding attack until it drops"
  requires log_detection via "must detect log before breaking" [0.95]
  requires motor_attack  via "provides the attack primitive"
  -- Causal: breaking a log causes a log item to drop ~1 tick later
  causes obtain_log via "log drop event" [0.95] [delay=1]
  -- Temporal: must face the log before attacking it
  precedes obtain_log via "attack action precedes item collection"

concept obtain_log
  domain minecraft
  description "Have at least one log in inventory after breaking"
  requires break_log         via "produces the log drop" [0.95]
  requires observe_inventory via "confirms inventory change"
  -- Causal: obtaining a log enables crafting planks
  causes craft_planks via "log in inventory enables crafting" [1.0]
  -- Instance: log is a subtype of wooden_item (enables analogy to planks, etc.)
  instance_of wooden_material via "logs are wood"

concept craft_planks
  domain minecraft
  description "Convert logs to planks (1 log → 4 planks) in inventory"
  requires obtain_log        via "needs logs to craft from" [0.95]
  requires observe_inventory via "monitors inventory for confirmation"
  -- A log composes_into planks (crafting recipe contributor)
  composes_into craft_crafting_table via "4 planks → crafting table" [0.95]
  composes_into craft_sticks         via "2 planks → 4 sticks" [0.95]
  causes craft_crafting_table via "planks enable table crafting" [0.90]
  instance_of wooden_material via "planks are processed wood"

concept craft_sticks
  domain minecraft
  description "Craft sticks from planks (2 planks → 4 sticks)"
  requires craft_planks      via "needs planks" [0.95]
  requires observe_inventory via "monitors inventory"
  composes_into craft_wooden_pickaxe via "sticks are part of pickaxe recipe" [0.95]
  composes_into craft_stone_pickaxe  via "sticks are part of pickaxe recipe" [0.95]
  instance_of wooden_material via "sticks are wood"

concept craft_crafting_table
  domain minecraft
  description "Craft a crafting table from 4 planks (3x3 grid required)"
  requires craft_planks      via "needs planks" [0.95]
  requires observe_inventory via "monitors inventory"
  causes place_crafting_table via "must have table to place it" [1.0]

concept place_crafting_table
  domain minecraft
  description "Place a crafting table block in the world"
  requires craft_crafting_table via "must have crafting table in inventory" [0.95]
  requires motor_use            via "uses the right-click place action"
  -- Temporal: crafting table must be placed before shaped crafting
  precedes craft_wooden_pickaxe via "table must be placed before using 3x3 grid"
  precedes craft_stone_pickaxe  via "table must be placed before using 3x3 grid"
  precedes craft_furnace        via "table must be placed before using 3x3 grid"

concept craft_wooden_pickaxe
  domain minecraft
  description "Craft a wooden pickaxe (3 planks + 2 sticks at crafting table)"
  requires craft_sticks         via "needs sticks" [0.95]
  requires place_crafting_table via "requires 3x3 crafting grid" [0.95]
  requires observe_inventory    via "monitors inventory"
  -- Both planks and sticks compose_into the pickaxe
  composes_into mine_stone via "wooden pickaxe required to mine stone" [0.95]
  causes mine_stone via "having a pickaxe enables stone mining" [0.90]
  instance_of tool via "a pickaxe is a tool"

concept mine_stone
  domain minecraft
  description "Break stone blocks with a wooden pickaxe; drops cobblestone"
  requires craft_wooden_pickaxe via "wooden pickaxe required to break stone" [0.95]
  requires motor_attack         via "provides the attack primitive"
  requires observe_inventory    via "confirms cobblestone in inventory"
  causes craft_stone_pickaxe via "cobblestone enables stone pickaxe" [0.95]
  causes craft_furnace       via "8 cobblestone enables furnace" [0.95]

concept craft_stone_pickaxe
  domain minecraft
  description "Craft a stone pickaxe (3 cobblestone + 2 sticks at table)"
  requires mine_stone           via "needs cobblestone" [0.95]
  requires place_crafting_table via "requires 3x3 crafting grid" [0.95]
  instance_of tool via "a stone pickaxe is a tool"

concept craft_furnace
  domain minecraft
  description "Craft a furnace from 8 cobblestone"
  requires mine_stone           via "needs 8 cobblestone" [0.95]
  requires place_crafting_table via "requires 3x3 crafting grid" [0.95]
  causes smelt_item via "furnace enables smelting" [1.0]

concept smelt_item
  domain minecraft
  description "Use furnace to smelt ore or cook food (fuel + input → output)"
  requires craft_furnace     via "furnace must exist" [0.95]
  requires motor_use         via "opens furnace and deposits items"

-- ===========================================================================
-- Supertype concepts (instance_of targets) — abstract categories
-- These have no processes; they serve as anchors for analogy spans.
-- ===========================================================================

concept wooden_material
  domain minecraft
  description "Abstract supertype for wood-derived materials (logs, planks, sticks)"

concept tool
  domain minecraft
  description "Abstract supertype for craftable tools (pickaxes, axes, shovels)"

-- ===========================================================================
-- Layer 4: Achievement DAG (motivational skeleton)
--
-- Minecraft's advancement tree.  Nodes are achievement milestones.
-- 'requires' edges encode epistemic ordering: to attempt B, the agent must
-- understand A.  No processes: discovering HOW to achieve these is the
-- agent's primary task.
--
-- Only early-game achievements are included in Phase A.
-- The full tree (~80 advancements) will be populated progressively.
-- ===========================================================================

-- Tier 1: First contact with the world

concept achieve_getting_wood
  domain minecraft
  description "Pick up a log for the first time (Java: 'Getting Wood')"
  requires obtain_log via "must have obtained a log to unlock this"

-- Tier 2: Basic crafting

concept achieve_benchmarking
  domain minecraft
  description "Craft a crafting table (Java: 'Benchmarking')"
  requires achieve_getting_wood     via "prerequisite in Minecraft achievement tree"
  requires craft_crafting_table     via "must know how to craft it" [0.80]

concept achieve_time_to_mine
  domain minecraft
  description "Use a crafting table to make a wooden pickaxe (Java: 'Time to Mine!')"
  requires achieve_benchmarking     via "prerequisite in Minecraft achievement tree"
  requires craft_wooden_pickaxe     via "must know how to craft it" [0.80]

concept achieve_time_to_farm
  domain minecraft
  description "Use a crafting table to make a hoe (Java: 'Time to Farm!')"
  requires achieve_benchmarking     via "prerequisite in Minecraft achievement tree"

concept achieve_bake_bread
  domain minecraft
  description "Turn wheat into bread (Java: 'Bake Bread')"
  requires achieve_time_to_farm     via "prerequisite in Minecraft achievement tree"

-- Tier 3: Stone age

concept achieve_getting_an_upgrade
  domain minecraft
  description "Construct a stone pickaxe (Java: 'Getting an Upgrade')"
  requires achieve_time_to_mine     via "prerequisite in Minecraft achievement tree"
  requires craft_stone_pickaxe      via "must know how to craft it" [0.80]

concept achieve_hot_topic
  domain minecraft
  description "Construct a furnace from cobblestone (Java: 'Hot Topic')"
  requires achieve_getting_an_upgrade via "prerequisite in Minecraft achievement tree"
  requires craft_furnace              via "must know how to craft it" [0.80]

-- Tier 4: Smelting and tools

concept achieve_acquire_hardware
  domain minecraft
  description "Smelt an iron ingot (Java: 'Acquiring Hardware')"
  requires achieve_hot_topic        via "prerequisite in Minecraft achievement tree"
  requires smelt_item               via "must know how to smelt" [0.80]

concept achieve_suit_up
  domain minecraft
  description "Protect yourself with a piece of iron armor (Java: 'Suit Up!')"
  requires achieve_acquire_hardware via "prerequisite in Minecraft achievement tree"

-- Tier 5: Iron age

concept achieve_time_to_strike
  domain minecraft
  description "Craft a sword (Java: 'Time to Strike!')"
  requires achieve_getting_an_upgrade via "prerequisite in Minecraft achievement tree"

concept achieve_monster_hunter
  domain minecraft
  description "Attack and kill a monster (Java: 'Monster Hunter')"
  requires achieve_time_to_strike   via "prerequisite in Minecraft achievement tree"
  requires entity_detection         via "must detect entity before engaging" [0.70]

-- Tier 6: Diamonds

concept achieve_diamonds
  domain minecraft
  description "Obtain diamonds (Java: 'DIAMONDS!')"
  requires achieve_acquire_hardware via "iron pickaxe needed to mine diamonds"
  requires craft_stone_pickaxe      via "stone pickaxe gates iron access" [0.80]

concept achieve_cover_me_with_diamonds
  domain minecraft
  description "Diamond armor (Java: 'Cover Me With Diamonds')"
  requires achieve_diamonds         via "prerequisite in Minecraft achievement tree"
