-- vision.ctkg - visual perception concepts for SymbolicAI
--
-- This domain defines the prerequisite hierarchy for visual learning.
-- The graph structure IS the classifier (Yoneda lemma):
--   cat = the concept that sits above cat_face_features in the prerequisite chain.
--
-- Built-in primitives (like succ/pred in arithmetic):
--   - DoG (retinal ganglion cells)
--   - Gabor / Gabor energy (V1 simple and complex cells)
--   - Innate face template (img_face_schematic, img_face_detect, etc.)
--   These are provided by modalities/vision.py and are NOT learned.
--
-- Learned via approximate synthesis (consolidate_approx):
--   - image_brightness, edge_response, texture_energy
--   - cat_face_features, cat
--
-- Transfer probabilities on edges encode Markov kernel weights:
--   - high (0.9+): strong structural dependency
--   - medium (0.7-0.8): partial dependency
--   - low (0.5-0.6): weak signal, contributes to Bayesian aggregate

interface vision_domain
  exports types image feature_score binary_label
  exports concepts visual_perception image_brightness edge_response texture_energy face_like_region cat_face_features cat

-- ---------------------------------------------------------------------------
-- Types
-- ---------------------------------------------------------------------------

type image         = seq(tuple(nat, nat, nat) ordered) ordered
type feature_score = nat metric
type binary_label  = symbol(0, 1)

-- ---------------------------------------------------------------------------
-- Base concept - analogous to the root 'number' concept in arithmetic
-- ---------------------------------------------------------------------------

concept visual_perception
  domain vision
  description "Raw visual sensory channel; signals that vision primitives are available"
  input image
  output feature_score

-- ---------------------------------------------------------------------------
-- Level 1 - single-feature concepts
-- Learned via approximate synthesis; each is a threshold on one feature.
-- ---------------------------------------------------------------------------

concept image_brightness
  domain vision
  description "Mean luminance above a threshold - simplest learnable visual concept"
  input image
  output binary_label
  requires visual_perception via "provides raw image access"

concept edge_response
  domain vision
  description "DoG response strength - proxy for local contrast and edge density"
  input image
  output binary_label
  requires visual_perception via "provides raw image access"

concept texture_energy
  domain vision
  description "Sum of multi-orientation Gabor energies - proxy for fur and fine texture"
  input image
  output binary_label
  requires edge_response via "carries" [0.9]

-- ---------------------------------------------------------------------------
-- Level 2 - face-aware concepts
-- These use the innate face primitives (img_face_score, img_face_detect).
-- ---------------------------------------------------------------------------

concept face_like_region
  domain vision
  description "Detects face-like schematic configuration using innate face template (Goren 1975)"
  input image
  output binary_label
  requires visual_perception via "provides raw image access"

concept cat_face_features
  domain vision
  description "Combination of texture (fur) and face geometry; approximate synthesis learns decision boundary"
  input image
  output binary_label
  requires texture_energy   via "provides" [0.80]
  requires face_like_region via "provides" [0.85]

-- ---------------------------------------------------------------------------
-- Level 3 - top-level cat concept
-- ---------------------------------------------------------------------------

concept cat
  domain vision
  description "Image containing a cat; MasteryState aggregates evidence from prerequisites"
  input image
  output binary_label
  requires cat_face_features via "contains"   [0.90]
  requires texture_energy    via "fur_present" [0.70]
  requires face_like_region  via "face_visible" [0.75]
