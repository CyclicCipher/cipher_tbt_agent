-- language.ctkg — Hierarchical language modelling domain.
--
-- Architecture (mirrors Broca's area hierarchy):
--
--   word_pos         (word -> POS)                  deterministic  -> synthesise
--       |
--   next_pos         (pos, pos -> next POS)          near-determ.  -> freq_consolidate
--       |
--   word_given_pos   (pos, pos, pos -> word)         distributional -> freq_consolidate
--       |
--   next_word        (word, word -> word)             composed       -> lookup chain
--
-- CRITICAL DESIGN: word_given_pos takes POS-level context (p1, p2, next_pos),
-- NOT word-level context.  This is what enables generalisation to unseen word
-- bigrams: we look up words by their POS category, not by the exact word pair.
-- With 9 POS tags, there are only 9^3 = 729 possible inputs to word_given_pos,
-- vs 10K^2 for flat word bigrams.  Most POS trigrams are seen during training.
--
-- Storage comparison (V=vocab, C=POS categories):
--   Flat bigram:   O(V^2) entries   100M for V=10K
--   POS hierarchy: O(V + C^2 + C^3) ~1K for C=9
--   Compression:   ~100,000x
--
-- Cross-domain note: replace 'word' with 'action', 'note', or 'state' and
-- the same 4-concept hierarchy handles Minecraft, music, or motor control.

-- ---------------------------------------------------------------------------
-- Types
-- ---------------------------------------------------------------------------

type word        = symbol ordered
-- A text token (lowercase, punctuation-stripped).

type pos_tag     = symbol(DET, NOUN, VERB, ADJ, ADV, PREP, CONJ, PRON, NUM, EXCL, PART)
-- Part-of-speech category.  Discrete, closed set.

type word_seq    = tuple(word, word)
-- Bigram context (last two words).

type pos_seq     = tuple(pos_tag, pos_tag)
-- Bigram context in POS space.

-- ---------------------------------------------------------------------------
-- Concepts
-- ---------------------------------------------------------------------------

concept word_pos
    domain      language
    description assign part-of-speech category to a word token
    input  word
    output pos_tag
    tier        axiom

concept next_pos
    domain      language
    description predict the next part-of-speech given a bigram POS context
    input  pos_tag pos_tag
    output pos_tag
    tier        theorem
    requires word_pos via "pos tagging prerequisite"

concept word_given_pos
    domain      language
    description predict next word given POS trigram context
    input  pos_tag pos_tag pos_tag
    output word
    tier        theorem
    requires next_pos via "POS prediction prerequisite"
    -- Input is (pos1, pos2, next_pos) -- all POS-level, no word context.
    -- This gives generalisation: 9^3=729 possible inputs vs 10K^2 for flat.
    -- The distributional task: given "DET NOUN -> VERB", what verb is it?
    -- Use freq_consolidate() since the same POS trigram precedes many words.

concept next_word
    domain      language
    description predict the next word given a bigram word context
    input  word word
    output word
    tier        theorem
    requires word_given_pos via "word prediction prerequisite"
    process
        p1 = lookup(word_pos, a)
        p2 = lookup(word_pos, b)
        p3 = lookup(next_pos, p1, p2)
        result = lookup(word_given_pos, p1, p2, p3)
        emit(result)
    -- Routes entirely through POS space: word -> POS -> POS_next -> word.
    -- Even unseen word bigrams (a, b) generalise: if (p1, p2) was seen in
    -- training, next_pos gives p3, and word_given_pos gives the most likely
    -- word for that POS trigram.

-- ---------------------------------------------------------------------------
-- Interface
-- ---------------------------------------------------------------------------

interface language
  exports types word pos_tag word_seq pos_seq
  exports concepts word_pos next_pos word_given_pos next_word
