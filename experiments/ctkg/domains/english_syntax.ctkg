-- english_syntax.ctkg — English parameterization of universal syntax
--
-- English: SVO word order, head-initial phrases, determiners required,
-- pre-nominal adjectives, prepositions (not postpositions).
--
-- Each concept instantiates a universal concept with English-specific
-- phrase structure rules. The functor maps universal -> English.

-- =========================================================================
-- English-specific types (supplements universal types)
-- =========================================================================

type pos_tag = symbol(N, V, ADJ, ADV, DET, ADP, CONJ, COMP, PRON, AUX, NUM, PART, INTJ, UNK)
type word = symbol
type word_seq = seq(word)
type pos_seq = seq(pos_tag)
type bio_tag = symbol(B_NP, I_NP, B_PP, I_PP, B_VP, I_VP, O)
type bio_seq = seq(bio_tag)
type clause_tag = symbol(SUBJ, PRED, OTHER)
type clause_seq = seq(clause_tag)

-- =========================================================================
-- Stage 1: English POS tagging
-- =========================================================================

concept en_lexical_category
  domain english_syntax
  description "English POS tagging using UD categories"
  input word_seq
  output pos_seq
  threshold 0.95
  max_epochs 100
  process scan(words, empty, lookup(word, en_lexicon))

-- =========================================================================
-- Stage 2: English NP chunking
-- =========================================================================

concept en_np_structure
  domain english_syntax
  description "English NP: Det? Adj* N (head-initial, pre-nominal modifiers)"
  input word_seq
  output bio_seq
  requires en_lexical_category via "POS tags identify NP constituents"
  threshold 0.95
  max_epochs 100
  process
    for word in words
      if pos(word) in (DET, ADJ) and next_head(word) == N then emit(B_NP or I_NP)
      elif pos(word) == N and in_np_context then emit(I_NP or B_NP)
      else emit(O)

-- =========================================================================
-- Stage 3: English PP chunking
-- =========================================================================

concept en_pp_structure
  domain english_syntax
  description "English PP: Prep NP (head-initial prepositions)"
  input word_seq
  output bio_seq
  requires en_np_structure via "PPs contain NP complements"
  threshold 0.95
  max_epochs 100
  process
    for word in words
      if pos(word) == ADP then emit(B_PP)
      elif in_pp_complement(word) then emit(I_PP)
      else emit(O)

-- =========================================================================
-- Stage 4: English VP chunking
-- =========================================================================

concept en_vp_structure
  domain english_syntax
  description "English VP: V NP? PP* (head-initial, SVO order)"
  input word_seq
  output bio_seq
  requires en_np_structure via "VP arguments are NPs"
  requires en_pp_structure via "VP adjuncts are PPs"
  threshold 0.95
  max_epochs 100
  process
    for word in words
      if pos(word) == V then emit(B_VP)
      elif in_vp_complement(word) then emit(I_VP)
      else emit(O)

-- =========================================================================
-- Stage 5: English clause structure
-- =========================================================================

concept en_simple_clause
  domain english_syntax
  description "English clause: NP_subj VP_pred (SVO order)"
  input word_seq
  output clause_seq
  requires en_np_structure via "Subject is an NP"
  requires en_vp_structure via "Predicate is a VP"
  threshold 0.95
  max_epochs 100
  process
    subj = find(phrases, NP, position=0)
    pred = find(phrases, VP, position=1)
    for word in words
      if in_span(word, subj) then emit(SUBJ)
      elif in_span(word, pred) then emit(PRED)
      else emit(OTHER)

-- =========================================================================
-- Functor: universal_syntax -> english_syntax
-- =========================================================================

functor english_instantiation
  from universal_syntax to english_syntax
  map lexical_category -> en_lexical_category
  map np_structure -> en_np_structure
  map pp_structure -> en_pp_structure
  map vp_structure -> en_vp_structure
  map simple_clause -> en_simple_clause
  preserves prerequisite_order
  preserves composition

-- =========================================================================
-- Adjunction: active/passive voice (deferred)
-- =========================================================================

-- adjunction active_passive
--   forward en_active_to_passive
--   inverse en_passive_to_active
--   unit active(passive(S)) = S
--   counit passive(active(S)) = S

-- =========================================================================
-- Interface
-- =========================================================================

interface english_syntax
  exports types pos_tag word bio_tag clause_tag
  exports concepts en_lexical_category en_np_structure en_pp_structure en_vp_structure en_simple_clause
