-- logic.ctkg — Propositional and predicate logic domain
--
-- Demonstrates multi-domain composition with arithmetic:
--   - Shares the 'bool' builtin type
--   - Defines its own types (prop, proof_step, etc.)
--   - Has cross-domain prerequisites where logic builds on comparison
--
-- This domain tests sheaf consistency: when merged with arithmetic,
-- shared types must agree.

-- =========================================================================
-- Type definitions
-- =========================================================================

-- Logical connectives and quantifiers
type connective = symbol(AND, OR, NOT, IMPLIES, IFF)
type quantifier = symbol(FORALL, EXISTS)
type truth_value = symbol(TRUE, FALSE)
type prop_var = symbol(P, Q, R, S, T)

-- Compound types
type literal = tagged(pos: prop_var, neg: prop_var)
type clause = seq(literal)
type formula = seq(clause)
type proof_step = tuple(proposition, connective, proposition)

-- =========================================================================
-- Stage 1: Truth Table Evaluation
-- =========================================================================

concept truth_eval
  domain logic
  description "Evaluate a connective applied to two truth values"
  input truth_value connective truth_value
  output truth_value
  atomic
  threshold 0.95
  max_epochs 100
  process emit(apply(connective, a, b))

-- =========================================================================
-- Stage 2: Negation
-- =========================================================================

concept negation
  domain logic
  description "Negate a truth value: NOT TRUE = FALSE, NOT FALSE = TRUE"
  input truth_value
  output truth_value
  atomic
  threshold 0.95
  max_epochs 100
  process emit(not(a))

-- =========================================================================
-- Stage 3: Compound Evaluation
-- =========================================================================

concept compound_eval
  domain logic
  description "Evaluate a compound proposition given variable assignments"
  input formula truth_value truth_value
  output truth_value
  requires truth_eval via "Connective evaluation is the base operation"
  requires negation via "Negation handles NOT subexpressions"
  threshold 0.95
  max_epochs 100
  process
    bindings = zip(vars(formula), assignments)
    result = fold(clauses(formula), TRUE, eval_clause(bindings))
    emit(result)

-- =========================================================================
-- Stage 4: Tautology Check
-- =========================================================================

concept tautology_check
  domain logic
  description "Check if a formula is true under all variable assignments"
  input formula
  output truth_value
  requires compound_eval via "Evaluation under specific assignments"
  threshold 0.95
  max_epochs 100
  process
    result = forall(assignment in assignments(formula), compound_eval(formula, assignment) == TRUE)
    emit(result)

-- =========================================================================
-- Stage 5: Modus Ponens
-- =========================================================================

concept modus_ponens
  domain logic
  description "Given P and P IMPLIES Q, derive Q"
  input proposition connective proposition
  output proposition
  requires compound_eval via "Need to evaluate implications"
  requires tautology_check via "Verify the inference is valid"
  threshold 0.95
  max_epochs 100
  process
    valid = and(equal(connective, IMPLIES), truth_eval(premise, IMPLIES, conclusion))
    emit(if(valid, conclusion, INVALID))

-- =========================================================================
-- Interface — what this domain exports for cross-domain composition
-- =========================================================================

interface logic
  exports types truth_value connective prop_var literal clause formula
  exports concepts truth_eval negation compound_eval tautology_check modus_ponens
