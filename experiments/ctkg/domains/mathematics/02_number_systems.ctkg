-- mathematics/02_number_systems.ctkg
-- Number systems: extending from natural numbers through complex numbers.
--
-- Extends arithmetic.ctkg + 00_types.ctkg + 01_elementary.ctkg.
-- Curriculum order:
--   Stage 1:  Signed integers (concept of negative numbers)
--   Stage 2:  Integer arithmetic (+, -, *, /)
--   Stage 3:  Absolute value and integer comparison
--   Stage 4:  Rational numbers (fractions as equivalence classes)
--   Stage 5:  Decimal representation (place value beyond ones)
--   Stage 6:  Decimal arithmetic
--   Stage 7:  Converting between fractions and decimals
--   Stage 8:  Real numbers (concept: rationals + irrationals)
--   Stage 9:  Irrational numbers (sqrt(2), pi)
--   Stage 10: Real arithmetic and the number line
--   Stage 11: Imaginary unit and complex numbers
--   Stage 12: Complex arithmetic
--   Stage 13: Complex conjugate and modulus
--   Stage 14: Polar form of complex numbers

-- =========================================================================
-- Stage 1: Signed Integers (concept of negatives)
-- =========================================================================

concept negative_number_concept
  domain number_systems
  description "Negative numbers represent quantities below zero; -n is the additive inverse of n"
  input nat
  output signed_int
  requires single_digit_subtraction via "negatives arise when subtraction yields debt: 3 - 5 = -2"
  requires comparison via "compare determines which direction from zero"
  -- Level A:
  --   s = if(compare(a, 0) == EQ, ZERO, POS)
  --   emit(s, a)

concept integer_absolute_value
  domain number_systems
  description "|n| = n if n >= 0, -n if n < 0: distance from zero"
  input signed_int
  output nat
  requires negative_number_concept via "absolute value undoes the sign of an integer"
  requires comparison via "check sign to decide which branch"
  -- Level A:
  --   result = if(sign == NEG, magnitude, magnitude)
  --   emit(result)

-- =========================================================================
-- Stage 2: Integer Arithmetic
-- =========================================================================

concept integer_addition
  domain number_systems
  description "Add signed integers: same signs add magnitudes, opposite signs subtract"
  input signed_int signed_int
  output signed_int
  requires negative_number_concept via "integer addition requires knowing what negatives mean"
  requires single_digit_addition via "add magnitudes when signs agree"
  requires single_digit_subtraction via "subtract magnitudes when signs differ"
  requires comparison via "compare magnitudes to determine result sign"
  -- Level A:
  --   if signs equal: result_mag = a_mag + b_mag, result_sign = a_sign
  --   if signs differ: larger - smaller, sign = sign of larger magnitude

concept integer_subtraction
  domain number_systems
  description "a - b = a + (-b): rewrite as addition of additive inverse"
  input signed_int signed_int
  output signed_int
  requires integer_addition via "subtraction is addition of the additive inverse"
  -- Level A:
  --   b_negated = flip_sign(b)
  --   result = lookup(integer_addition, a, b_negated)
  --   emit(result)

adjunction int_add_sub
  forward integer_addition
  inverse integer_subtraction
  unit (a + b) - b = a
  counit (a - b) + b = a

concept integer_multiplication
  domain number_systems
  description "a * b: multiply magnitudes; sign is POS if signs match, NEG if they differ"
  input signed_int signed_int
  output signed_int
  requires multiplication via "multiply magnitudes using natural number multiplication"
  requires negative_number_concept via "sign rules: (+)(+)=+, (-)(-)=+, (+)(-)=-, (-)(+)=-"
  -- Level A:
  --   mag = lookup(multiplication, a_mag, b_mag)
  --   s = if(equal(a_sign, b_sign), POS, NEG)
  --   emit(s, mag)

concept integer_division
  domain number_systems
  description "a / b: divide magnitudes; sign rules same as multiplication; round toward zero"
  input signed_int signed_int
  output signed_int
  requires division via "divide magnitudes"
  requires integer_multiplication via "sign rules match multiplication"
  requires comparison via "verify divisor is nonzero"

-- =========================================================================
-- Stage 3: Integer Ordering and Number Line
-- =========================================================================

concept integer_comparison
  domain number_systems
  description "Compare signed integers: use sign first, then magnitude"
  input signed_int signed_int
  output cmp_result
  requires negative_number_concept via "negatives are always less than positives"
  requires comparison via "compare magnitudes when signs are equal"
  requires integer_absolute_value via "compare absolute values for same-sign integers"
  -- Level A:
  --   if a_sign = POS and b_sign = NEG: emit(GT)
  --   if a_sign = NEG and b_sign = POS: emit(LT)
  --   if both POS: lookup(comparison, a_mag, b_mag)
  --   if both NEG: flip lookup(comparison, a_mag, b_mag)

-- =========================================================================
-- Stage 4: Rational Numbers
-- =========================================================================

concept rational_number
  domain number_systems
  description "A rational number is any value expressible as p/q, q != 0; an equivalence class of fractions"
  input simple_fraction
  output expr
  requires fraction_simplification via "a rational is the simplest form a/b with GCD(a,b) = 1"
  requires fraction_equivalence via "different fractions may represent the same rational (2/4 = 1/2)"
  -- Level C: fraction equivalence classes require symbolic representation

concept rational_ordering
  domain number_systems
  description "Compare rationals a/b and c/d by cross-multiplication: a*d vs b*c"
  input simple_fraction simple_fraction
  output cmp_result
  requires multiplication via "cross-multiply to compare: a*d versus c*b"
  requires comparison via "compare products to determine order"
  -- Level A:
  --   left = lookup(multiplication, a, d)
  --   right = lookup(multiplication, c, b)
  --   result = lookup(comparison, left, right)
  --   emit(result)

-- =========================================================================
-- Stage 5: Decimal Representation
-- =========================================================================

concept decimal_place_value
  domain number_systems
  description "A decimal is a sum of digits times powers of 10: 3.14 = 3 + 1/10 + 4/100"
  input expr_seq
  output expr
  requires exponentiation via "place values are powers of 10"
  requires multiplication via "digit * 10^position gives place value"
  requires fraction_multiplication via "fractional positions use 1/10^n"
  requires single_digit_addition via "sum all place values"
  -- Level C: requires positional notation parsing

concept fraction_to_decimal
  domain number_systems
  description "Convert p/q to decimal by long division: p / q until remainder repeats or terminates"
  input simple_fraction
  output expr
  requires long_division via "perform long division to generate decimal digits"
  requires remainder via "track remainder to detect termination or repeating block"
  -- Level C: requires detection of repeating block

concept decimal_to_fraction
  domain number_systems
  description "Convert terminating decimal to fraction: 0.75 = 75/100, simplified"
  input expr
  output simple_fraction
  requires multiplication via "multiply by 10^(decimal_places) to clear decimal point"
  requires fraction_simplification via "reduce resulting fraction"
  requires exponentiation via "compute 10^n for n decimal places"
  -- Level C: requires decimal digit counting

-- =========================================================================
-- Stage 6: Decimal Arithmetic
-- =========================================================================

concept decimal_addition
  domain number_systems
  description "Add decimals by aligning decimal points and adding column by column"
  input expr expr
  output expr
  requires decimal_place_value via "align decimal points using place value understanding"
  requires two_digit_arithmetic via "column addition with carry handles the digit-level arithmetic"
  -- Level C: requires place-aligned symbolic addition

concept decimal_multiplication
  domain number_systems
  description "Multiply decimals: multiply as integers, then place decimal point"
  input expr expr
  output expr
  requires multi_digit_multiplication via "multiply ignoring decimal points"
  requires decimal_place_value via "count decimal places in both factors to position the decimal"
  -- Level C: decimal point placement requires digit counting

-- =========================================================================
-- Stage 7: Real Numbers (concept)
-- =========================================================================

concept irrational_number_concept
  domain number_systems
  description "Irrationals are non-repeating, non-terminating decimals: sqrt(2), pi, e"
  input nat
  output expr
  requires integer_square_root via "recognise when sqrt(n) is not an integer (n not a perfect square)"
  requires prime_factorization via "sqrt(n) is irrational when n has a prime factor with odd exponent"
  requires fraction_to_decimal via "irrationals cannot be expressed as p/q: see contrast"
  -- Level C: proving irrationality requires proof by contradiction (Level 2 logic primitives)

concept real_number_arithmetic
  domain number_systems
  description "Arithmetic on real numbers: combines rational arithmetic with irrational simplification"
  input expr expr
  output expr
  requires rational_number via "rationals are a dense subset of the reals"
  requires irrational_number_concept via "irrationals complete the real line"
  requires decimal_addition via "approximation via decimal expansion"
  -- Level C: general real arithmetic requires symbolic representation

-- =========================================================================
-- Stage 8: Complex Numbers
-- =========================================================================

concept imaginary_unit
  domain number_systems
  description "i^2 = -1: the imaginary unit resolves sqrt(-1); defined by this property"
  input nat
  output expr
  requires irrational_number_concept via "i extends the real line: sqrt(-1) needs a new number type"
  requires exponentiation via "i is defined by the property that i^2 = -1"
  -- Level C: definition by symbolic equation; i^4 = 1 cycle pattern

concept complex_number
  domain number_systems
  description "A complex number z = a + bi: real part a and imaginary part b"
  input expr expr
  output expr
  requires imaginary_unit via "complex numbers use i as the imaginary unit"
  requires real_number_arithmetic via "real and imaginary parts are real numbers"
  -- Level C: complex numbers are a field extension of the reals

concept complex_addition
  domain number_systems
  description "(a+bi) + (c+di) = (a+c) + (b+d)i: add real parts and imaginary parts separately"
  input expr expr
  output expr
  requires complex_number via "inputs must be complex numbers"
  requires real_number_arithmetic via "add real parts and imaginary parts using real arithmetic"
  -- Level C:
  --   real_sum = a + c
  --   imag_sum = b + d
  --   emit(real_sum, imag_sum)  -- representing (real_sum) + (imag_sum)i

adjunction complex_add_sub
  forward complex_addition
  inverse complex_subtraction
  unit (a+bi) + (c+di) - (c+di) = a+bi
  counit (a+bi) - (c+di) + (c+di) = a+bi

concept complex_subtraction
  domain number_systems
  description "(a+bi) - (c+di) = (a-c) + (b-d)i"
  input expr expr
  output expr
  requires complex_addition via "subtraction is addition of the additive inverse"
  requires real_number_arithmetic via "subtract real and imaginary parts"

concept complex_multiplication
  domain number_systems
  description "(a+bi)(c+di) = (ac-bd) + (ad+bc)i using FOIL and i^2=-1"
  input expr expr
  output expr
  requires complex_number via "inputs are complex numbers"
  requires real_number_arithmetic via "multiply components using real arithmetic"
  requires imaginary_unit via "i^2 = -1 transforms the bd term to -bd (real)"
  -- Level C: FOIL + i^2 substitution

concept complex_modulus
  domain number_systems
  description "|a+bi| = sqrt(a^2 + b^2): distance from origin in the complex plane"
  input expr
  output expr
  requires complex_number via "modulus is defined for complex numbers"
  requires integer_square_root via "modulus = sqrt of sum of squares"
  requires multiplication via "compute a^2 and b^2"
  requires real_number_arithmetic via "a^2 + b^2 is real arithmetic"

concept complex_conjugate
  domain number_systems
  description "conj(a+bi) = a-bi: reflect over real axis; z * conj(z) = |z|^2"
  input expr
  output expr
  requires complex_number via "conjugate is defined for complex numbers"
  requires complex_multiplication via "z * conj(z) = |z|^2 (useful property)"
  requires complex_modulus via "z * conj(z) = |z|^2 connects conjugate to modulus"

-- =========================================================================
-- Interface export
-- =========================================================================

interface number_systems
  exports concepts negative_number_concept integer_absolute_value
  exports concepts integer_addition integer_subtraction integer_multiplication integer_division
  exports concepts integer_comparison rational_number rational_ordering
  exports concepts decimal_place_value fraction_to_decimal decimal_to_fraction
  exports concepts decimal_addition decimal_multiplication
  exports concepts irrational_number_concept real_number_arithmetic
  exports concepts imaginary_unit complex_number complex_addition complex_subtraction
  exports concepts complex_multiplication complex_modulus complex_conjugate
