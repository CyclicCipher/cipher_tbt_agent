-- mathematics/01_elementary.ctkg
-- Elementary mathematics: multiplication through fraction arithmetic.
--
-- Builds on arithmetic.ctkg (two_digit_arithmetic) and 00_types.ctkg.
-- Curriculum order:
--   Stage 1: Multiplication (repeated addition)
--   Stage 2: Division + Remainder (inverse of multiplication)
--   Stage 3: Exponentiation (repeated multiplication)
--   Stage 4: Integer square root (inverse of squaring)
--   Stage 5: GCD via Euclidean algorithm
--   Stage 6: LCM via GCD
--   Stage 7: Multi-digit multiplication (column algorithm)
--   Stage 8: Long division
--   Stage 9: Order of operations (PEMDAS)
--   Stage 10: Prime checking and factorization
--   Stage 11: Fraction equivalence and simplification
--   Stage 12: Fraction arithmetic (add, sub, mul, div)
--
-- Process levels:
--   Level A — executable with current interpreter primitives
--   Level B — needs fold2 (binary fold: fold(n, init, fn, extra_arg))
--   Level C — needs Level 3 symbolic/rewrite primitives

-- =========================================================================
-- Stage 1: Multiplication (repeated addition)
-- =========================================================================

concept multiplication
  domain elementary
  description "a * b by folding b additions of a onto 0: fold(b, 0, add_a)"
  input nat nat
  output nat
  requires single_digit_addition via "multiplication is repeated addition; adds a to accumulator b times"
  requires comparison via "multiplication needs zero-check for base case (0 * b = 0)"
  -- Level B: fold2(b, 0, single_digit_addition, a)
  -- The fold2 primitive applies fn(acc, a) n times from init, i.e.:
  --   result = 0; for i in range(b): result = result + a

adjunction mul_div_adjunction
  forward multiplication
  inverse division
  unit (a * b) / b = a
  counit (a / b) * b + remainder(a, b) = a

-- =========================================================================
-- Stage 2: Division and Remainder
-- =========================================================================

concept division
  domain elementary
  description "a / b = floor(a/b): how many times b fits into a via repeated subtraction"
  input nat nonzero_digit
  output nat
  requires multiplication via "division is the inverse of multiplication; verify via multiply-back"
  requires single_digit_subtraction via "subtract divisor from dividend repeatedly"
  requires comparison via "stop when remainder < divisor"
  -- Level B: count steps of repeated subtraction until remainder < divisor

concept remainder
  domain elementary
  description "a mod b = a - b * floor(a/b): what is left after division"
  input nat nonzero_digit
  output nat
  requires division via "remainder = dividend - divisor * quotient"
  requires multiplication via "multiply quotient by divisor to subtract"
  requires single_digit_subtraction via "subtract to get remainder"
  -- Level A (after division is known):
  --   q = lookup(division, a, b)
  --   product = lookup(multiplication, q, b)
  --   r = a - product
  --   emit(r)

-- =========================================================================
-- Stage 3: Exponentiation (repeated multiplication)
-- =========================================================================

concept exponentiation
  domain elementary
  description "a^b by folding b multiplications of a onto 1: fold(b, 1, mul_a)"
  input nat nat
  output nat
  requires multiplication via "exponentiation is repeated multiplication; multiplies a by accumulator b times"
  -- Level B: fold2(b, 1, multiplication, a)
  -- Special cases: a^0 = 1, 0^0 undefined (convention: 1)

-- =========================================================================
-- Stage 4: Integer Square Root (inverse of squaring)
-- =========================================================================

concept integer_square_root
  domain elementary
  description "floor(sqrt(n)): largest k such that k*k <= n; found by linear search"
  input nat
  output nat
  requires exponentiation via "square root is inverse of k^2; check by squaring candidates"
  requires comparison via "compare k^2 against n to find the threshold"
  -- Level B: scan from 0 upward until k^2 > n, return k-1

-- =========================================================================
-- Stage 5: GCD via Euclidean Algorithm
-- =========================================================================

concept greatest_common_divisor
  domain elementary
  description "GCD(a,b): largest divisor of both; Euclidean: GCD(a,0)=a, GCD(a,b)=GCD(b, a mod b)"
  input nat nat
  output nat
  requires remainder via "Euclidean algorithm replaces (a,b) with (b, a mod b) until b=0"
  requires comparison via "check whether b is zero (base case)"
  -- Level B: iterative fold applying the Euclidean step until remainder = 0

-- =========================================================================
-- Stage 6: LCM via GCD
-- =========================================================================

concept least_common_multiple
  domain elementary
  description "LCM(a,b) = a * b / GCD(a,b): smallest multiple of both"
  input nat nat
  output nat
  requires greatest_common_divisor via "LCM formula requires GCD"
  requires multiplication via "compute a * b"
  requires division via "divide by GCD"
  -- Level A (after above are known):
  --   g = lookup(greatest_common_divisor, a, b)
  --   product = lookup(multiplication, a, b)
  --   result = lookup(division, product, g)
  --   emit(result)

-- =========================================================================
-- Stage 7: Multi-Digit Multiplication (column / partial products)
-- =========================================================================

concept multi_digit_multiplication
  domain elementary
  description "Multi-digit multiplication via partial products with carry propagation"
  input nat nat
  output nat
  requires multiplication via "single-digit * single-digit is the base product operation"
  requires two_digit_arithmetic via "add partial products using column addition with carry"
  -- Level C: requires digit decomposition, partial product generation, column summation

-- =========================================================================
-- Stage 8: Long Division
-- =========================================================================

concept long_division
  domain elementary
  description "Long division: divide multi-digit dividend by divisor digit-by-digit"
  input nat nonzero_digit
  output nat_pair
  requires division via "single-digit division at each step"
  requires multi_digit_multiplication via "multiply quotient digit by divisor"
  requires two_digit_arithmetic via "subtract at each step and bring down next digit"
  -- Level C: requires digit-by-digit positional decomposition

-- =========================================================================
-- Stage 9: Order of Operations (PEMDAS / BODMAS)
-- =========================================================================

concept order_of_operations
  domain elementary
  description "Evaluate arithmetic expression respecting precedence: Exponents > Mul/Div > Add/Sub"
  input expr
  output expr
  requires exponentiation via "exponentiation has highest precedence among binary ops"
  requires multiplication via "multiplication before addition"
  requires division via "division before addition"
  requires single_digit_addition via "addition evaluated last"
  requires single_digit_subtraction via "subtraction evaluated last"
  -- Level C: requires expression parsing, precedence tree construction, and evaluation

-- =========================================================================
-- Stage 10: Primes and Factorization
-- =========================================================================

concept prime_check
  domain elementary
  description "is n prime? No divisors between 2 and floor(sqrt(n))"
  input nat
  output bool
  requires integer_square_root via "only need to check divisors up to sqrt(n)"
  requires remainder via "n is composite iff remainder(n, k) = 0 for some 2 <= k <= sqrt(n)"
  requires comparison via "compare remainder to zero; compare k to sqrt limit"
  -- Level B: fold divisor candidates from 2 to sqrt(n), check remainder = 0

concept prime_factorization
  domain elementary
  description "Decompose n into prime factors: n = p1^e1 * p2^e2 * ... (trial division)"
  input nat
  output expr_seq
  requires prime_check via "identify which divisors are prime"
  requires division via "divide out each prime factor repeatedly"
  requires remainder via "check exact divisibility (remainder = 0)"
  -- Level C: requires symbolic sequence construction

-- =========================================================================
-- Stage 11: Fraction Equivalence and Simplification
-- =========================================================================

concept fraction_equivalence
  domain elementary
  description "a/b = c/d iff a*d = b*c (cross-multiplication test)"
  input simple_fraction simple_fraction
  output bool
  requires multiplication via "cross-multiply: a*d and b*c"
  requires comparison via "check equality of products"
  -- Level A:
  --   left = lookup(multiplication, a, d)
  --   right = lookup(multiplication, b, c)
  --   result = if(compare(left, right) == EQ, True, False)
  --   emit(result)

concept fraction_simplification
  domain elementary
  description "Reduce a/b to lowest terms: divide numerator and denominator by GCD(a,b)"
  input simple_fraction
  output simple_fraction
  requires greatest_common_divisor via "find GCD of numerator and denominator"
  requires division via "divide numerator and denominator by GCD"
  -- Level A:
  --   g = lookup(greatest_common_divisor, a, b)
  --   num = lookup(division, a, g)
  --   den = lookup(division, b, g)
  --   emit(num, den)

-- =========================================================================
-- Stage 12: Fraction Arithmetic
-- =========================================================================

concept fraction_addition
  domain elementary
  description "(a/b) + (c/d) = (a*d + c*b) / (b*d), then simplify"
  input simple_fraction simple_fraction
  output simple_fraction
  requires least_common_multiple via "find LCD = LCM(b, d) for efficient computation"
  requires multiplication via "scale numerators to common denominator"
  requires single_digit_addition via "add scaled numerators"
  requires fraction_simplification via "reduce result to lowest terms"
  -- Level B: multi-step computation using lookup chain

concept fraction_multiplication
  domain elementary
  description "(a/b) * (c/d) = (a*c) / (b*d), then simplify"
  input simple_fraction simple_fraction
  output simple_fraction
  requires multiplication via "multiply numerator * numerator and denominator * denominator"
  requires fraction_simplification via "reduce product to lowest terms"
  -- Level A (after above):
  --   num = lookup(multiplication, a, c)
  --   den = lookup(multiplication, b, d)
  --   result = lookup(fraction_simplification, num, den)
  --   emit(result)

adjunction frac_add_sub
  forward fraction_addition
  inverse fraction_subtraction
  unit (a/b + c/d) - c/d = a/b
  counit (a/b - c/d) + c/d = a/b

concept fraction_subtraction
  domain elementary
  description "(a/b) - (c/d) = (a*d - c*b) / (b*d), then simplify"
  input simple_fraction simple_fraction
  output simple_fraction
  requires fraction_addition via "subtraction is addition of negated fraction (share same LCD logic)"
  requires single_digit_subtraction via "subtract numerators"
  requires fraction_simplification via "reduce to lowest terms"

concept fraction_division
  domain elementary
  description "(a/b) / (c/d) = (a/b) * (d/c) = (a*d) / (b*c): multiply by reciprocal"
  input simple_fraction simple_fraction
  output simple_fraction
  requires fraction_multiplication via "dividing by fraction = multiplying by its reciprocal"
  requires fraction_simplification via "reduce result"
  -- Level A:
  --   result = lookup(fraction_multiplication, a, b, d, c)
  --   emit(result)

-- =========================================================================
-- Interface export
-- =========================================================================

interface elementary
  exports concepts multiplication division remainder exponentiation
  exports concepts integer_square_root greatest_common_divisor least_common_multiple
  exports concepts multi_digit_multiplication long_division order_of_operations
  exports concepts prime_check prime_factorization
  exports concepts fraction_equivalence fraction_simplification
  exports concepts fraction_addition fraction_subtraction fraction_multiplication fraction_division
