-- mathematics/05_calculus.ctkg
-- Calculus: from limits through multivariable calculus and Taylor series.
--
-- Extends 00_types.ctkg through 04_geometry.ctkg.
-- All processes at this level are Level C (symbolic) except where noted.
--
-- Curriculum order:
--   Stage 1:  Sequence limits
--   Stage 2:  Function limits and continuity
--   Stage 3:  The derivative (limit definition)
--   Stage 4:  Differentiation rules (power, product, chain, quotient)
--   Stage 5:  Implicit differentiation
--   Stage 6:  Applications of derivatives (optimization, related rates)
--   Stage 7:  Antiderivatives and indefinite integrals
--   Stage 8:  Riemann sums
--   Stage 9:  The definite integral
--   Stage 10: Fundamental Theorem of Calculus
--   Stage 11: Integration techniques (substitution, by parts)
--   Stage 12: Improper integrals
--   Stage 13: Sequences and series
--   Stage 14: Convergence tests
--   Stage 15: Power series and Taylor/Maclaurin series
--   Stage 16: Introduction to multivariable calculus

-- =========================================================================
-- Stage 1: Sequence Limits
-- =========================================================================

concept sequence_limit
  domain calculus
  description "lim_{n->inf} a_n = L: a_n can be made arbitrarily close to L for large n"
  input expr expr
  output expr
  requires geometric_sequence via "geometric sequences illustrate convergence: |r|<1 -> 0"
  requires arithmetic_sequence via "arithmetic sequences diverge unless common difference is 0"
  requires real_number_arithmetic via "limit value L is a real number"
  -- Level C: limit as formal epsilon-N definition; informal: evaluate a_n for large n

concept convergence_vs_divergence
  domain calculus
  description "Classify whether a sequence converges (has a finite limit) or diverges"
  input expr
  output bool
  requires sequence_limit via "convergence means the limit exists and is finite"
  requires comparison via "compare a_n to L using absolute value for epsilon-N check"
  requires irrational_number_concept via "limits can be irrational (e, pi, sqrt(2))"
  -- Level C: formal epsilon-N verification

-- =========================================================================
-- Stage 2: Function Limits and Continuity
-- =========================================================================

concept function_limit
  domain calculus
  description "lim_{x->a} f(x) = L: two-sided limit; left and right limits must agree"
  input expr expr
  output expr
  requires sequence_limit via "function limit is a generalization of sequence limit (x->a via sequences)"
  requires real_number_arithmetic via "f(x) values are real; limit L is real"
  requires rational_expression via "limits of rational functions often evaluated by substitution or factoring"
  -- Level C: epsilon-delta definition; informal: algebraic evaluation

concept limit_laws
  domain calculus
  description "Limit distributes over +, -, *, /; lim(cf) = c*lim(f); Squeeze theorem"
  input expr expr
  output expr
  requires function_limit via "limit laws describe how limits interact with arithmetic"
  requires real_number_arithmetic via "apply arithmetic to limit values"
  -- Level C: symbolic rewrite rules for limits

concept continuity
  domain calculus
  description "f continuous at a iff lim_{x->a} f(x) = f(a): limit equals function value"
  input expr expr
  output bool
  requires function_limit via "continuity is defined in terms of limits"
  requires algebraic_substitution via "evaluate f(a) by substituting x = a"
  requires comparison via "check if limit equals the function value at a"
  -- Level C: three-part continuity check (limit exists, f(a) defined, they agree)

-- =========================================================================
-- Stage 3: The Derivative (Limit Definition)
-- =========================================================================

concept derivative_definition
  domain calculus
  description "f'(x) = lim_{h->0} (f(x+h) - f(x))/h: instantaneous rate of change"
  input expr
  output expr
  requires function_limit via "derivative is a specific type of limit as h->0"
  requires integer_subtraction via "numerator f(x+h) - f(x) is a difference"
  requires division via "divide by h"
  requires algebraic_substitution via "substitute (x+h) into f to compute f(x+h)"
  -- Level C: symbolic limit computation after algebraic simplification

concept differentiability
  domain calculus
  description "f differentiable at a iff the derivative limit exists; implies continuity"
  input expr expr
  output bool
  requires derivative_definition via "differentiability means the derivative limit exists"
  requires continuity via "differentiability implies continuity (but not vice versa)"
  -- Level C: check existence of two-sided limit

-- =========================================================================
-- Stage 4: Differentiation Rules
-- =========================================================================

concept power_rule
  domain calculus
  description "d/dx(x^n) = n*x^(n-1): the fundamental rule for differentiating monomials"
  input expr expr
  output expr
  requires derivative_definition via "power rule is proved from the limit definition"
  requires exponentiation via "derivative involves x^(n-1)"
  requires multiplication via "coefficient becomes n"
  requires integer_subtraction via "exponent decreases by 1: n -> n-1"
  -- Level C:
  --   new_coef = n * coefficient
  --   new_exp = n - 1
  --   emit(new_coef, new_exp)

concept sum_and_constant_rules
  domain calculus
  description "(f+g)' = f' + g'; (cf)' = c*f': derivative is linear"
  input expr
  output expr
  requires derivative_definition via "linearity follows directly from limit definition"
  requires power_rule via "apply to each term in the sum"
  requires polynomial_addition via "add resulting derivative terms"

concept product_rule
  domain calculus
  description "(fg)' = f'g + fg': derivative of a product of two functions"
  input expr expr
  output expr
  requires derivative_definition via "product rule proved from limit definition"
  requires sum_and_constant_rules via "product rule result is a sum of two terms"
  requires multiplication via "compute f'g and fg' terms"

concept quotient_rule
  domain calculus
  description "(f/g)' = (f'g - fg') / g^2: derivative of a ratio"
  input expr expr
  output expr
  requires product_rule via "quotient rule equivalent to product rule applied to f * g^(-1)"
  requires integer_subtraction via "numerator f'g - fg' is a difference"
  requires exponentiation via "denominator is g^2"
  requires division via "divide numerator by g^2"

concept chain_rule
  domain calculus
  description "d/dx[f(g(x))] = f'(g(x)) * g'(x): derivative of a composition"
  input expr expr
  output expr
  requires derivative_definition via "chain rule proved from limit definition via substitution"
  requires algebraic_substitution via "evaluate f' at g(x): substitute g(x) into f'"
  requires multiplication via "multiply f'(g(x)) by g'(x)"

concept trig_derivatives
  domain calculus
  description "d/dx(sin x) = cos x; d/dx(cos x) = -sin x; and derived trig derivatives"
  input trig_fn_name expr
  output expr
  requires chain_rule via "trig derivatives with arguments use chain rule"
  requires trig_functions via "trig functions are the inputs and outputs"
  requires pythagorean_trig_identity via "trig identities simplify derivative expressions"
  -- Level C: proved from limit definition using squeeze theorem

concept exponential_and_log_derivatives
  domain calculus
  description "d/dx(e^x) = e^x; d/dx(ln x) = 1/x; chain rule extends these"
  input expr
  output expr
  requires chain_rule via "exponential/log derivatives with arguments use chain rule"
  requires exponential_function via "base function is e^x"
  requires logarithm via "log derivative is the inverse function"
  -- Level C: derive from definition using limit lim_{h->0} (e^h - 1)/h = 1

-- =========================================================================
-- Stage 5: Applications of Derivatives
-- =========================================================================

concept implicit_differentiation
  domain calculus
  description "Differentiate both sides of F(x,y)=0 treating y as function of x; solve for dy/dx"
  input equation
  output expr
  requires chain_rule via "d/dx[f(y)] = f'(y) * dy/dx uses chain rule (y is composite)"
  requires linear_equation via "after differentiating, solve for dy/dx algebraically"
  requires trig_derivatives via "implicit differentiation often involves trig equations"

concept critical_points
  domain calculus
  description "f'(c) = 0 or undefined: candidates for local maxima, minima, or saddle points"
  input expr
  output expr_seq
  requires power_rule via "find f'(x)"
  requires sum_and_constant_rules via "differentiate all terms"
  requires linear_equation via "solve f'(x) = 0 for x"
  requires quotient_rule via "f'(x) undefined where denominator = 0"

concept first_second_derivative_test
  domain calculus
  description "First test: sign change of f' at c. Second test: sign of f''(c) determines max/min"
  input expr expr
  output expr
  requires critical_points via "apply test at critical points only"
  requires power_rule via "compute f''(x) by differentiating f'(x)"
  requires comparison via "check sign of f''(c): positive = min, negative = max"

concept optimization
  domain calculus
  description "Find maximum or minimum of a function: model, differentiate, find critical points, verify"
  input expr interval
  output expr
  requires first_second_derivative_test via "optimization applies derivative tests to find extrema"
  requires algebraic_substitution via "evaluate function at critical points and endpoints"
  requires comparison via "compare values to identify global maximum/minimum"
  -- Level C: modeling step (word problem to function) requires Level 3 decompose

concept related_rates
  domain calculus
  description "Differentiate a relationship equation with respect to t; solve for desired rate"
  input equation expr
  output expr
  requires implicit_differentiation via "differentiate relationship equation with respect to t"
  requires pythagorean_theorem via "many related rates problems use geometric relationships"
  requires linear_equation via "solve for the unknown rate after differentiation"

-- =========================================================================
-- Stage 6: Antiderivatives and Indefinite Integrals
-- =========================================================================

concept antiderivative
  domain calculus
  description "F is an antiderivative of f if F'=f; the family F(x)+C; reverse of differentiation"
  input expr
  output expr
  requires derivative_definition via "antiderivative is the inverse operation to differentiation"
  requires power_rule via "reverse power rule: integral of x^n = x^(n+1)/(n+1)"
  requires integer_addition via "exponent increases by 1"
  requires division via "divide by new exponent"
  -- Level C: symbolic integration rules

adjunction diff_antidiff
  forward derivative_definition
  inverse antiderivative
  unit d/dx[integral(f(x)dx)] = f(x)
  counit integral(f'(x)dx) = f(x) + C

concept integral_linearity
  domain calculus
  description "integral(f+g)dx = integral(f)dx + integral(g)dx; integral(cf)dx = c*integral(f)dx"
  input expr
  output expr
  requires antiderivative via "linearity of integration follows from linearity of differentiation"
  requires sum_and_constant_rules via "antiderivative mirrors linear rules of derivative"

-- =========================================================================
-- Stage 7: Riemann Sums and the Definite Integral
-- =========================================================================

concept riemann_sum
  domain calculus
  description "Sum_i f(x_i*) * delta_x: approximate area under curve by summing rectangle areas"
  input expr interval nat
  output expr
  requires triangle_area via "each rectangle area is base * height"
  requires real_number_arithmetic via "sum over n rectangles with width (b-a)/n"
  requires sequence_limit via "Riemann sum converges to integral as n -> infinity"
  requires polygon_perimeter via "summing n rectangle areas (fold over index)"
  -- Level B: fold over n rectangles summing f(x_i) * delta_x

concept definite_integral
  domain calculus
  description "integral_a^b f(x)dx = lim_{n->inf} Riemann_sum(f, a, b, n): signed area under curve"
  input expr interval
  output expr
  requires riemann_sum via "definite integral is the limit of Riemann sums"
  requires sequence_limit via "limit of Riemann sums as n -> infinity"
  requires continuity via "continuous functions on [a,b] are Riemann integrable"
  -- Level C: limit evaluation of Riemann sum

concept integral_properties
  domain calculus
  description "Properties: integral_a^a=0; integral_a^b=-integral_b^a; additivity on [a,b]+[b,c]"
  input expr interval
  output expr
  requires definite_integral via "properties follow from the Riemann sum definition"
  requires comparison via "check bounds for sign convention"

-- =========================================================================
-- Stage 8: Fundamental Theorem of Calculus
-- =========================================================================

concept fundamental_theorem_calculus_1
  domain calculus
  description "FTC Part 1: d/dx[integral_a^x f(t)dt] = f(x); differentiation undoes integration"
  input expr interval
  output expr
  requires definite_integral via "FTC 1 differentiates the area function A(x) = integral_a^x f"
  requires derivative_definition via "differentiation is applied to the area accumulation function"
  requires continuity via "f must be continuous for FTC 1 to hold"

concept fundamental_theorem_calculus_2
  domain calculus
  description "FTC Part 2: integral_a^b f(x)dx = F(b) - F(a) where F'=f: evaluate via antiderivative"
  input expr interval
  output expr
  requires fundamental_theorem_calculus_1 via "FTC 2 follows from FTC 1"
  requires antiderivative via "find antiderivative F, evaluate at bounds"
  requires integer_subtraction via "compute F(b) - F(a)"
  -- Level C: find antiderivative symbolically, substitute bounds

-- =========================================================================
-- Stage 9: Integration Techniques
-- =========================================================================

concept integration_by_substitution
  domain calculus
  description "u-substitution: let u = g(x), then integral(f(g(x))g'(x)dx) = integral(f(u)du)"
  input expr
  output expr
  requires antiderivative via "u-substitution transforms an integral into a simpler form"
  requires chain_rule via "substitution reverses the chain rule"
  requires algebraic_substitution via "substitute u = g(x) and du = g'(x)dx"
  -- Level C: pattern match for chain-rule-shaped integrands

concept integration_by_parts
  domain calculus
  description "integral(u dv) = uv - integral(v du): derived from product rule; use LIATE rule"
  input expr
  output expr
  requires antiderivative via "integration by parts transforms one integral into another"
  requires product_rule via "integration by parts reverses the product rule"
  requires algebraic_substitution via "choose u and dv from the integrand"
  -- Level C: symbolic choice of u (LIATE heuristic) and dv

concept partial_fraction_decomposition
  domain calculus
  description "Decompose rational function into partial fractions for integration"
  input expr_seq expr_seq
  output expr
  requires rational_expression via "input is a rational function P(x)/Q(x)"
  requires linear_system_elimination via "solve for partial fraction coefficients"
  requires factor_trinomial via "factor the denominator Q(x)"
  requires linear_equation via "match coefficients to find A, B, C, ..."
  -- Level C: symbolic partial fraction decomposition

-- =========================================================================
-- Stage 10: Improper Integrals
-- =========================================================================

concept improper_integral
  domain calculus
  description "integral_a^inf or integral over discontinuity: take limit of proper integrals"
  input expr interval
  output expr
  requires definite_integral via "improper integral is a limit of definite integrals"
  requires function_limit via "limit as bound -> infinity or approach of discontinuity"
  requires convergence_vs_divergence via "determine if the limit exists (converges) or not"
  -- Level C: evaluate proper integral then take limit

-- =========================================================================
-- Stage 11: Sequences and Series
-- =========================================================================

concept infinite_series
  domain calculus
  description "Sum_n a_n = lim_{N->inf} Sum_{n=1}^N a_n: limit of partial sums"
  input expr
  output expr
  requires convergence_vs_divergence via "series converges iff partial sums converge"
  requires sequence_limit via "partial sum S_N = Sum_{n=1}^N a_n must converge"
  requires geometric_sequence via "geometric series Sum a*r^n = a/(1-r) for |r|<1"
  -- Level C: compute limit of partial sums

concept series_convergence_tests
  domain calculus
  description "Ratio test, root test, comparison test, integral test, alternating series test"
  input expr
  output bool
  requires infinite_series via "tests determine if a series converges or diverges"
  requires function_limit via "ratio test uses lim |a_{n+1}/a_n|"
  requires comparison via "comparison test: if |a_n| <= b_n and sum(b_n) converges then sum(a_n) converges"
  requires definite_integral via "integral test: series converges iff corresponding improper integral converges"
  -- Level C: apply appropriate test based on series form

-- =========================================================================
-- Stage 12: Power Series and Taylor Series
-- =========================================================================

concept power_series
  domain calculus
  description "Sum c_n * (x-a)^n: radius of convergence R; converges for |x-a| < R"
  input expr_seq expr expr
  output expr
  requires infinite_series via "power series is an infinite series in powers of (x-a)"
  requires series_convergence_tests via "ratio test gives radius of convergence"
  requires geometric_sequence via "geometric series is the simplest power series: 1/(1-x) = Sum x^n"
  -- Level C: determine interval of convergence via ratio test

concept taylor_series
  domain calculus
  description "f(x) = Sum f^(n)(a)/n! * (x-a)^n: represents f as power series around x=a"
  input expr expr
  output expr_seq
  requires power_series via "Taylor series is a specific power series with c_n = f^(n)(a)/n!"
  requires derivative_definition via "compute n-th derivative f^(n)(a) at center a"
  requires factorial via "n! in denominator of each term"
  requires trig_derivatives via "Taylor series of sin, cos require iterated trig derivatives"
  requires exponential_and_log_derivatives via "Taylor series of e^x, ln(1+x)"
  -- Level C: symbolic iterated differentiation and coefficient extraction

-- =========================================================================
-- Supporting concept needed for Taylor series
-- =========================================================================

concept factorial
  domain calculus
  description "n! = n * (n-1) * ... * 2 * 1: n factorial (0! = 1 by convention)"
  input nat
  output nat
  requires multiplication via "factorial is iterated multiplication: fold(n, 1, multiply_by_n)"
  requires comparison via "base case: if n=0, result is 1"
  -- Level B: fold2(n, 1, multiplication, n) -- actually needs decreasing n
  -- Level B: fold over 1..n multiplying accumulator by each value

-- =========================================================================
-- Stage 13: Introduction to Multivariable Calculus
-- =========================================================================

concept partial_derivative
  domain calculus
  description "df/dx: differentiate f(x,y) with respect to x, treating y as constant"
  input expr expr
  output expr
  requires derivative_definition via "partial derivative applies single-variable differentiation"
  requires algebraic_substitution via "hold one variable constant (treat as a number)"
  requires chain_rule via "partial derivatives compose like full derivatives"
  -- Level C: symbolic differentiation treating specified variable as constant

concept gradient
  domain calculus
  description "grad(f) = (df/dx, df/dy): vector of all partial derivatives; points uphill"
  input expr
  output vector_2d
  requires partial_derivative via "gradient assembles all first partial derivatives"
  requires vector_addition via "gradient is a vector; addition is component-wise"
  -- Level C: compute both partials and form vector

-- =========================================================================
-- Interface export
-- =========================================================================

interface calculus
  exports concepts sequence_limit convergence_vs_divergence
  exports concepts function_limit limit_laws continuity
  exports concepts derivative_definition differentiability
  exports concepts power_rule sum_and_constant_rules product_rule quotient_rule chain_rule
  exports concepts trig_derivatives exponential_and_log_derivatives
  exports concepts implicit_differentiation critical_points first_second_derivative_test
  exports concepts optimization related_rates
  exports concepts antiderivative integral_linearity
  exports concepts riemann_sum definite_integral integral_properties
  exports concepts fundamental_theorem_calculus_1 fundamental_theorem_calculus_2
  exports concepts integration_by_substitution integration_by_parts partial_fraction_decomposition
  exports concepts improper_integral
  exports concepts infinite_series series_convergence_tests power_series
  exports concepts factorial taylor_series
  exports concepts partial_derivative gradient
