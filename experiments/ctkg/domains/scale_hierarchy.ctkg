-- scale_hierarchy.ctkg — Multi-scale hierarchical structure discovery
--
-- Inspired by Broca's area: simultaneous multi-scale processing where
-- each level discovers structure and bootstraps the next.
--
-- Key insight: the same distributional clustering algorithm (induce_hierarchy)
-- works at any scale.  PMI chunking connects adjacent scales: high-cohesion
-- pairs at scale L become atoms at scale L+1.  The result is a bottom-up
-- hierarchy that requires NO labels, NO grammar rules, NO external tools.
--
--   char → morpheme → word → phrase → clause → sentence → paragraph → concept
--
-- The prerequisite structure IS the scale structure: next_morph requires
-- next_char because morphemes are composed of chars.  You cannot discover
-- phrase structure without first knowing what the words are.
--
-- Usage:
--   python discover_structure.py --corpus EarlyModernLatin --levels 4
--   python discover_structure.py --corpus WikiText-2 --levels 6 --save hier.json
--
-- The same pipeline applies to non-language domains:
--   music:    note → motif → phrase → section → movement → piece
--   action:   action → sub-routine → skill → strategy → plan → goal
--   vision:   pixel → patch → feature → object → scene → narrative

-- =========================================================================
-- Scale types — each level is a compressed version of the level below
-- =========================================================================

type char       = symbol   -- Unicode code point — the surface
type morpheme   = symbol   -- High-PMI char n-gram (syllable / bound morpheme)
type word       = symbol   -- Whitespace-delimited token (free morpheme)
type phrase     = symbol   -- High-PMI word n-gram (constituency group)
type clause     = symbol   -- High-PMI phrase n-gram (predication unit)
type sentence   = symbol   -- High-PMI clause n-gram (complete thought)
type paragraph  = symbol   -- High-PMI sentence n-gram (discourse unit)
type concept    = symbol   -- High-PMI paragraph n-gram (semantic / topic unit)

-- Discovered category types — output of induce_hierarchy at each scale.
-- Items with similar forward distributions are assigned the same category.
type char_cat    = symbol   -- phonological / typographic category
type morph_cat   = symbol   -- morphological category (prefix / suffix / root)
type word_cat    = symbol   -- syntactic category (POS-like, label-free)
type phrase_cat  = symbol   -- phrase function category
type clause_cat  = symbol   -- clause type category
type sent_cat    = symbol   -- sentence type category

-- =========================================================================
-- Level 0: Characters
-- =========================================================================

concept next_char
  domain scale_hierarchy
  description "Character bigram forward distribution — base scale"
  input char
  output char
  tier theorem

  -- Trained: ai.teach('next_char', (ch,), (ch_next,)) for all adjacent chars
  -- Clustered: ai.induce_hierarchy_bidir('next_char', 'prev_char', n_clusters=12)
  -- Discovers: Q-before-U, script boundaries, ligatures, case-ending patterns
  -- Example clusters: {Q,q}→u, Greek={α,β,γ...}, punctuation={.,;,:}

concept prev_char
  domain scale_hierarchy
  description "Character bigram backward distribution — categorical dual of next_char"
  input char
  output char
  requires next_char via "bidirectional pair"
  tier theorem

  -- Trained: ai.teach('prev_char', (ch,), (ch_prev,)) for all adjacent chars
  -- Combined with next_char for richer distributional clustering.
  -- P(prev | X) constrains what CAN precede X, complementing P(next | X).
  -- E.g. 'u' follows 'q' (next_char) AND 'q' precedes 'u' (prev_char confirms it).

-- =========================================================================
-- Level 1: Morphemes (compressed from chars by PMI chunking)
-- =========================================================================

concept chunk_chars
  domain scale_hierarchy
  description "Compress adjacent chars into morphemes via PMI chunking"
  input char
  output morpheme
  requires next_char
  tier theorem

  -- Built: ai.chunk_store('next_char', min_pmi=3.0)
  -- Returns: [(a, b, compound, pmi), ...] — high-PMI char pairs
  -- Expected for Latin: 'qu', 'ae', 'nt', 'st', 'er', 'us', 'um', 'is', 'am'
  -- apply_chunks(char_seq, chunk_map) → morpheme sequence

concept next_morph
  domain scale_hierarchy
  description "Morpheme bigram forward distribution"
  input morpheme
  output morpheme
  requires chunk_chars
  tier theorem

  -- Trained on corpus with char chunks applied
  -- Discovers: morphological categories (prefix cluster, suffix cluster, root)

concept prev_morph
  domain scale_hierarchy
  description "Morpheme bigram backward distribution — categorical dual of next_morph"
  input morpheme
  output morpheme
  requires next_morph via "bidirectional pair"
  tier theorem

-- =========================================================================
-- Level 2: Words (natural whitespace boundary or compressed from morphemes)
-- =========================================================================

concept chunk_morphs
  domain scale_hierarchy
  description "Compress adjacent morphemes into words via PMI chunking"
  input morpheme
  output word
  requires next_morph
  tier theorem

concept next_word_hier
  domain scale_hierarchy
  description "Word bigram forward distribution (distributional, label-free)"
  input word
  output word
  requires chunk_morphs
  tier theorem

  -- Trained on whitespace-tokenised corpus
  -- Same machinery as Phase O discover_test.py — POS-like clusters without labels
  -- Discovers: DET-like, NOUN-like, VERB-like, PREP-like clusters

concept prev_word_hier
  domain scale_hierarchy
  description "Word bigram backward distribution — categorical dual of next_word_hier"
  input word
  output word
  requires next_word_hier via "bidirectional pair"
  tier theorem

  -- Combined with next_word_hier: word preceded by DET must be NOUN/ADJ,
  -- so clustering on both forward (what follows DET) and backward (what precedes
  -- NOUN) gives sharper POS-like categories than forward-only clustering.

-- =========================================================================
-- Level 3: Phrases (high-PMI word n-grams)
-- =========================================================================

concept chunk_words
  domain scale_hierarchy
  description "Compress adjacent words into phrases via PMI chunking"
  input word
  output phrase
  requires next_word_hier
  tier theorem

  -- Expected for Latin: 'per se', 'id est', 'ad hoc', 'qua', 'vel'
  -- Expected for English: 'of the', 'in the', 'according to', 'such as'

concept next_phrase
  domain scale_hierarchy
  description "Phrase bigram forward distribution"
  input phrase
  output phrase
  requires chunk_words
  tier theorem

concept prev_phrase
  domain scale_hierarchy
  description "Phrase bigram backward distribution — categorical dual of next_phrase"
  input phrase
  output phrase
  requires next_phrase via "bidirectional pair"
  tier theorem

-- =========================================================================
-- Level 4: Clauses
-- =========================================================================

concept chunk_phrases
  domain scale_hierarchy
  description "Compress adjacent phrases into clauses via PMI chunking"
  input phrase
  output clause
  requires next_phrase
  tier theorem

concept next_clause
  domain scale_hierarchy
  description "Clause bigram forward distribution"
  input clause
  output clause
  requires chunk_phrases
  tier theorem

concept prev_clause
  domain scale_hierarchy
  description "Clause bigram backward distribution — categorical dual of next_clause"
  input clause
  output clause
  requires next_clause via "bidirectional pair"
  tier theorem

-- =========================================================================
-- Level 5: Sentences
-- =========================================================================

concept chunk_clauses
  domain scale_hierarchy
  description "Compress adjacent clauses into sentences via PMI chunking"
  input clause
  output sentence
  requires next_clause
  tier theorem

concept next_sent
  domain scale_hierarchy
  description "Sentence bigram forward distribution"
  input sentence
  output sentence
  requires chunk_clauses
  tier theorem

concept prev_sent
  domain scale_hierarchy
  description "Sentence bigram backward distribution — categorical dual of next_sent"
  input sentence
  output sentence
  requires next_sent via "bidirectional pair"
  tier theorem

-- =========================================================================
-- Level 6: Paragraphs
-- =========================================================================

concept chunk_sents
  domain scale_hierarchy
  description "Compress adjacent sentences into paragraphs via PMI chunking"
  input sentence
  output paragraph
  requires next_sent
  tier theorem

concept next_para
  domain scale_hierarchy
  description "Paragraph bigram forward distribution"
  input paragraph
  output paragraph
  requires chunk_sents
  tier theorem

concept prev_para
  domain scale_hierarchy
  description "Paragraph bigram backward distribution — categorical dual of next_para"
  input paragraph
  output paragraph
  requires next_para via "bidirectional pair"
  tier theorem

-- =========================================================================
-- Level 7: Concepts (semantic / topic units)
-- =========================================================================

concept chunk_paras
  domain scale_hierarchy
  description "Compress adjacent paragraphs into concept units via PMI chunking"
  input paragraph
  output concept
  requires next_para
  tier theorem

concept next_concept
  domain scale_hierarchy
  description "Concept bigram forward distribution — top of the hierarchy"
  input concept
  output concept
  requires chunk_paras
  tier theorem

concept prev_concept
  domain scale_hierarchy
  description "Concept bigram backward distribution — categorical dual of next_concept"
  input concept
  output concept
  requires next_concept via "bidirectional pair"
  tier theorem

-- =========================================================================
-- Interface
-- =========================================================================

interface scale_hierarchy
  exports types char morpheme word phrase clause sentence paragraph concept
  exports types char_cat morph_cat word_cat phrase_cat clause_cat sent_cat
  exports concepts next_char prev_char next_morph prev_morph next_word_hier prev_word_hier
  exports concepts next_phrase prev_phrase next_clause prev_clause next_sent prev_sent
  exports concepts next_para prev_para next_concept prev_concept
  exports concepts chunk_chars chunk_morphs chunk_words chunk_phrases chunk_clauses chunk_sents chunk_paras
