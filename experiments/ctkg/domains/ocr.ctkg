-- ocr.ctkg — Optical Character Recognition domain
--
-- Defines the structural skeleton for the symbolic AI's visual reading
-- capability.  The learned content (ExampleStores) is stored separately
-- in ocr_knowledge.json (checkpoint).
--
-- Three-phase discovery pipeline (discover_chars.py):
--   Phase 1: Raw GT text -> next_char bigrams -> char categories
--   Phase 2: Raw image patches -> next_glyph bigrams -> glyph categories
--   Phase 3: Paired (image, text) -> glyph_reads_as alignment table
--
-- Transfer:
--   Train once with discover_chars.py --align --save ocr_knowledge.json
--   Load in any new AI:
--     ai = SymbolicAI(merge(parse_file('arithmetic.ctkg'), parse_file('ocr.ctkg')))
--     ai.load_checkpoint('ocr_knowledge.json')
--     char = ai.ask('glyph_reads_as', (glyph_cluster_id,))
--
-- Design principle: no external OCR library, no pre-built font templates.
-- Structure from distributions alone.

-- =========================================================================
-- Type definitions
-- =========================================================================

-- A single Unicode character (the reading output)
type char = symbol ordered

-- A learned character category ID (integer index assigned by induce_hierarchy)
-- Phonological/morphological groupings: vowels, fricatives, word-boundary chars, etc.
type char_cat = symbol

-- A quantized image patch hash (output of _quantize() from visual_symbol.py)
-- String representation of the discretised pixel distribution
type glyph_hash = symbol

-- A learned glyph cluster ID (integer index assigned by induce_hierarchy)
-- Visual groupings: letter-shaped patches, space patches, punctuation patches, etc.
type glyph_cat = symbol

-- =========================================================================
-- Phase 1: Character language structure
-- =========================================================================

concept next_char
  domain language
  description "Predict next character from current character (bigram forward distribution)"
  input char
  output char
  tier theorem

  -- Trained by: ai.teach('next_char', (ch,), (ch_next,)) for all adjacent pairs in GT text
  -- Clustered by: ai.induce_hierarchy('next_char', n_clusters=12)
  -- Result: phonological/morphological char categories (vowels, fricatives, Q/u cluster, etc.)

-- =========================================================================
-- Phase 2: Visual glyph structure
-- =========================================================================

concept next_glyph
  domain vision
  description "Predict next glyph patch from current glyph patch (visual bigram forward distribution)"
  input glyph_hash
  output glyph_hash
  tier theorem

  -- Trained by: ai.teach('next_glyph', (hash_i,), (hash_i+1,)) for adjacent patches in line images
  -- Clustered by: ai.induce_hierarchy('next_glyph', n_clusters=64)
  -- Result: visual glyph categories (letter patches, space patches, punctuation patches, etc.)

-- =========================================================================
-- Phase 3: Glyph-to-character alignment
-- =========================================================================

concept glyph_reads_as
  domain reading
  description "Map a visual glyph category to the character it most likely represents"
  input glyph_cat
  output char
  requires next_char
  requires next_glyph
  tier theorem

  -- Trained by: ai.teach('glyph_reads_as', (glyph_cid,), (char,)) for aligned pairs
  -- Consolidated by: ai.freq_consolidate('glyph_reads_as')
  -- Queried by: ai.ask('glyph_reads_as', (glyph_cluster_id,)) -> ('a',)
  --
  -- This IS the lookup table: ExampleStore maps glyph_cat -> most frequent char.
  -- No dict literal needed -- ai.ask() consults ExampleStore directly.
  --
  -- Future (Phase S.6): consolidate() emits process: lookup(glyph_reads_as, first(X))
  -- embedded in a higher-level read_glyph concept, making ocr.ctkg self-contained.

-- =========================================================================
-- Interface: what the OCR domain exports
-- =========================================================================

interface
  exports glyph_reads_as
  exports next_char
