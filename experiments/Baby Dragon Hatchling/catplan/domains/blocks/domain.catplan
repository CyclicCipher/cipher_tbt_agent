-- Blocks World domain in CatPlan
-- Uses derived predicates and conditional effects.

category BlocksWorld where

  -- Types
  type Block
  type Surface = Block | Table
  type Hand

  -- Base predicates (stored in state)
  pred on       : Block -> Block -> Prop
  pred on_table : Block -> Prop
  pred holding  : Hand -> Block -> Prop
  pred empty    : Hand -> Prop

  -- Derived predicates (computed, not stored)
  derived clear(b : Block) = not(exists b2 : Block . on(b2, b))

  -- Invariants
  invariant "hand holds at most one block"
    forall h : Hand . count(b : Block . holding(h, b)) <= 1

  -- Actions
  action pick(h : Hand, b : Block)
    require empty(h)
    require clear(b)
    effect holding(h, b)
    effect not(empty(h))
    effect not(on_table(b))
    when on(b, x) : not(on(b, x))

  action place_on_table(h : Hand, b : Block)
    require holding(h, b)
    effect on_table(b)
    effect empty(h)
    effect not(holding(h, b))

  action stack(h : Hand, b : Block, target : Block)
    require holding(h, b)
    require clear(target)
    require b /= target
    effect on(b, target)
    effect empty(h)
    effect not(holding(h, b))

  -- D.1: Composite action (macro-operator)
  compose pick_and_stack(h : Hand, b : Block, target : Block) = stack(h, b, target) . pick(h, b)
