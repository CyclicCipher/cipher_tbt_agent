-- Blocks World: Tier 1 problems (single-step or two-step)

problem move_a_onto_b
  domain BlocksWorld
  objects
    hand : Hand
    a : Block
    b : Block
  init
    empty(hand)
    on_table(a)
    on_table(b)
    clear(a)
    clear(b)
  goal
    on(a, b)

problem unstack_a
  domain BlocksWorld
  objects
    hand : Hand
    a : Block
    b : Block
  init
    empty(hand)
    on(a, b)
    on_table(b)
    clear(a)
  goal
    on_table(a)
    on_table(b)

problem swap_top
  domain BlocksWorld
  objects
    hand : Hand
    a : Block
    b : Block
    c : Block
  init
    empty(hand)
    on(a, b)
    on_table(b)
    on_table(c)
    clear(a)
    clear(c)
  goal
    on(c, b)
    on_table(a)
