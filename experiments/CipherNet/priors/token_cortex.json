    {"source": "tc_fast:L23", "target": "inhibitor", "type": "temporal", "weight": 0.15},
    {"source": "tc_mid:L23",  "target": "inhibitor", "type": "temporal", "weight": 0.15},
    {"source": "tc_slow:L23", "target": "inhibitor", "type": "temporal", "weight": 0.15},
    {"source": "inhibitor", "target": "tc_fast:L23", "type": "spatial", "weight": -0.2},
    {"source": "inhibitor", "target": "tc_mid:L23",  "type": "spatial", "weight": -0.2},
    {"source": "inhibitor", "target": "tc_slow:L23", "type": "spatial", "weight": -0.2}
  ],

  "properties": {
    "description": "A1-analog for text tokens. Three temporal scales create diverse representations: fast columns detect token onsets and carry precise timing (position) information. Medium columns detect transitions between tokens. Slow columns preserve token identity for downstream processing. The same architecture works for audio (phoneme onset, vowel sustain, consonant transition)."
  }
}
