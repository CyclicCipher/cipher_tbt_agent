{
  "name": "token_cortex",
  "description": "Primary sensory cortex for sequential token input (A1 analog). Three columns with different temporal dynamics create diversity of timescales: fast (transient/onset), medium (transition), slow (sustained/identity). Functional specialization emerges from temporal properties, not hardcoded labels. Designed to be repurposable for audio input. Feeds the temporal cortex hierarchy (STG) after preprocessing.",

  "nodes": [
    {"id": "tc_fast:L4",  "layer": 4,  "role": "input",    "temporal_scale": "fast",   "description": "Fast column input. Low self-loop = transient response (onset-like)."},
    {"id": "tc_fast:L23", "layer": 23, "role": "process",  "temporal_scale": "fast"},
    {"id": "tc_fast:L5",  "layer": 5,  "role": "output",   "temporal_scale": "fast"},
    {"id": "tc_fast:L6",  "layer": 6,  "role": "feedback", "temporal_scale": "fast"},

    {"id": "tc_mid:L4",  "layer": 4,  "role": "input",    "temporal_scale": "medium", "description": "Medium column input. Moderate decay = transition detection."},
    {"id": "tc_mid:L23", "layer": 23, "role": "process",  "temporal_scale": "medium"},
    {"id": "tc_mid:L5",  "layer": 5,  "role": "output",   "temporal_scale": "medium"},
    {"id": "tc_mid:L6",  "layer": 6,  "role": "feedback", "temporal_scale": "medium"},

    {"id": "tc_slow:L4",  "layer": 4,  "role": "input",    "temporal_scale": "slow",  "description": "Slow column input. High self-loop = sustained identity preservation."},
    {"id": "tc_slow:L23", "layer": 23, "role": "process",  "temporal_scale": "slow"},
    {"id": "tc_slow:L5",  "layer": 5,  "role": "output",   "temporal_scale": "slow"},
    {"id": "tc_slow:L6",  "layer": 6,  "role": "feedback", "temporal_scale": "slow"},

    {"id": "inhibitor", "role": "inhibitor", "description": "Lateral inhibition for dynamic competition between temporal scales."}
  ],

  "edges": [
    {"_comment": "=== tc_fast column (transient, onset-like) ==="},
    {"source": "tc_fast:L4",  "target": "tc_fast:L23", "type": "temporal", "weight": 1.0},
    {"source": "tc_fast:L23", "target": "tc_fast:L5",  "type": "temporal", "weight": 1.0},
    {"source": "tc_fast:L5",  "target": "tc_fast:L6",  "type": "temporal", "weight": 1.0},
    {"source": "tc_fast:L6",  "target": "tc_fast:L4",  "type": "temporal", "weight": 0.5},
    {"source": "tc_fast:L23", "target": "tc_fast:L23", "type": "temporal", "weight": 0.1, "description": "Very low self-loop: fast decay, transient response."},

    {"_comment": "=== tc_mid column (transition detection) ==="},
    {"source": "tc_mid:L4",  "target": "tc_mid:L23", "type": "temporal", "weight": 1.0},
    {"source": "tc_mid:L23", "target": "tc_mid:L5",  "type": "temporal", "weight": 1.0},
    {"source": "tc_mid:L5",  "target": "tc_mid:L6",  "type": "temporal", "weight": 1.0},
    {"source": "tc_mid:L6",  "target": "tc_mid:L4",  "type": "temporal", "weight": 0.5},
    {"source": "tc_mid:L23", "target": "tc_mid:L23", "type": "temporal", "weight": 0.4, "description": "Medium self-loop: captures transitions between tokens."},

    {"_comment": "=== tc_slow column (sustained, identity-preserving) ==="},
    {"source": "tc_slow:L4",  "target": "tc_slow:L23", "type": "temporal", "weight": 1.0},
    {"source": "tc_slow:L23", "target": "tc_slow:L5",  "type": "temporal", "weight": 1.0},
    {"source": "tc_slow:L5",  "target": "tc_slow:L6",  "type": "temporal", "weight": 1.0},
    {"source": "tc_slow:L6",  "target": "tc_slow:L4",  "type": "temporal", "weight": 0.5},
    {"source": "tc_slow:L23", "target": "tc_slow:L23", "type": "temporal", "weight": 0.8, "description": "High self-loop: sustained response, preserves token identity."},

    {"_comment": "=== Hierarchy feedforward (fast → mid → slow) ==="},
    {"source": "tc_fast:L23", "target": "tc_mid:L4",  "type": "temporal", "weight": 0.5, "description": "Onset feeds transition detector."},
    {"source": "tc_mid:L23",  "target": "tc_slow:L4", "type": "temporal", "weight": 0.5, "description": "Transition feeds sustained column."},

    {"_comment": "=== Hierarchy feedback (slow → mid → fast, skip L4) ==="},
    {"source": "tc_slow:L5",  "target": "tc_mid:L23",  "type": "temporal", "weight": 0.3},
    {"source": "tc_mid:L5",   "target": "tc_fast:L23", "type": "temporal", "weight": 0.3},

