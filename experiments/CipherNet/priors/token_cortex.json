    {"source": "id7:L4", "target": "id7:L23", "type": "temporal", "weight": 1.0},
    {"source": "id7:L23", "target": "id7:L5", "type": "temporal", "weight": 1.0},
    {"source": "id7:L5", "target": "id7:L6", "type": "temporal", "weight": 1.0},
    {"source": "id7:L6", "target": "id7:L4", "type": "temporal", "weight": 0.5},
    {"source": "id7:L23", "target": "id7:L23", "type": "temporal", "weight": 0.6},

    {"_comment": "Identity columns use POPULATION CODE, not WTA."},
    {"_comment": "Like A1 tonotopic columns: all respond proportionally."},
    {"_comment": "Competition happens downstream. identity_inhibitor disconnected."}
  ],

  "properties": {
    "description": "Tokentopic map with 8 identity columns + 3 temporal columns. Identity columns specialize through competitive learning (lateral inhibition forces WTA). Direct input edges from input columns (added in train.py) provide the identity signal. Temporal columns provide onset/transition/sustained dynamics via relay_token. For audio: identity columns become frequency-tuned, temporal columns stay the same."
  }
}
