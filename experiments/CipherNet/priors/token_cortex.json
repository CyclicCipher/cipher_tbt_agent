{
  "name": "token_cortex",
  "description": "Primary sensory cortex for sequential token input (A1 analog). Tokentopic map: identity columns specialize for different tokens through learning (like A1's tonotopic map for frequency). Temporal columns provide onset/transition/sustained dynamics. Repurposable for audio.",

  "nodes": [
    {"_comment": "=== TEMPORAL COLUMNS (onset, transition, sustained) ==="},
    {"id": "tc_fast:L4",  "layer": 4,  "role": "input",    "column_type": "temporal"},
    {"id": "tc_fast:L23", "layer": 23, "role": "process",  "column_type": "temporal"},
    {"id": "tc_fast:L5",  "layer": 5,  "role": "output",   "column_type": "temporal"},
    {"id": "tc_fast:L6",  "layer": 6,  "role": "feedback", "column_type": "temporal"},

    {"id": "tc_mid:L4",  "layer": 4,  "role": "input",    "column_type": "temporal"},
    {"id": "tc_mid:L23", "layer": 23, "role": "process",  "column_type": "temporal"},
    {"id": "tc_mid:L5",  "layer": 5,  "role": "output",   "column_type": "temporal"},
    {"id": "tc_mid:L6",  "layer": 6,  "role": "feedback", "column_type": "temporal"},

    {"id": "tc_slow:L4",  "layer": 4,  "role": "input",    "column_type": "temporal"},
    {"id": "tc_slow:L23", "layer": 23, "role": "process",  "column_type": "temporal"},
    {"id": "tc_slow:L5",  "layer": 5,  "role": "output",   "column_type": "temporal"},
    {"id": "tc_slow:L6",  "layer": 6,  "role": "feedback", "column_type": "temporal"},

    {"_comment": "=== IDENTITY COLUMNS (tokentopic map — specialize through learning) ==="},
    {"_comment": "8 generic columns. Initially identical. Specialize via competitive learning."},
    {"_comment": "Like A1 tonotopic columns that sharpen their frequency tuning with experience."},

    {"id": "id0:L4",  "layer": 4,  "role": "input",    "column_type": "identity"},
    {"id": "id0:L23", "layer": 23, "role": "process",  "column_type": "identity"},
    {"id": "id0:L5",  "layer": 5,  "role": "output",   "column_type": "identity"},
    {"id": "id0:L6",  "layer": 6,  "role": "feedback", "column_type": "identity"},

    {"id": "id1:L4",  "layer": 4,  "role": "input",    "column_type": "identity"},
    {"id": "id1:L23", "layer": 23, "role": "process",  "column_type": "identity"},
    {"id": "id1:L5",  "layer": 5,  "role": "output",   "column_type": "identity"},
    {"id": "id1:L6",  "layer": 6,  "role": "feedback", "column_type": "identity"},

    {"id": "id2:L4",  "layer": 4,  "role": "input",    "column_type": "identity"},
    {"id": "id2:L23", "layer": 23, "role": "process",  "column_type": "identity"},
    {"id": "id2:L5",  "layer": 5,  "role": "output",   "column_type": "identity"},
    {"id": "id2:L6",  "layer": 6,  "role": "feedback", "column_type": "identity"},

    {"id": "id3:L4",  "layer": 4,  "role": "input",    "column_type": "identity"},
    {"id": "id3:L23", "layer": 23, "role": "process",  "column_type": "identity"},
    {"id": "id3:L5",  "layer": 5,  "role": "output",   "column_type": "identity"},
    {"id": "id3:L6",  "layer": 6,  "role": "feedback", "column_type": "identity"},

    {"id": "id4:L4",  "layer": 4,  "role": "input",    "column_type": "identity"},
    {"id": "id4:L23", "layer": 23, "role": "process",  "column_type": "identity"},
    {"id": "id4:L5",  "layer": 5,  "role": "output",   "column_type": "identity"},
    {"id": "id4:L6",  "layer": 6,  "role": "feedback", "column_type": "identity"},

    {"id": "id5:L4",  "layer": 4,  "role": "input",    "column_type": "identity"},
    {"id": "id5:L23", "layer": 23, "role": "process",  "column_type": "identity"},
    {"id": "id5:L5",  "layer": 5,  "role": "output",   "column_type": "identity"},
    {"id": "id5:L6",  "layer": 6,  "role": "feedback", "column_type": "identity"},

    {"id": "id6:L4",  "layer": 4,  "role": "input",    "column_type": "identity"},
    {"id": "id6:L23", "layer": 23, "role": "process",  "column_type": "identity"},
    {"id": "id6:L5",  "layer": 5,  "role": "output",   "column_type": "identity"},
    {"id": "id6:L6",  "layer": 6,  "role": "feedback", "column_type": "identity"},

    {"id": "id7:L4",  "layer": 4,  "role": "input",    "column_type": "identity"},
    {"id": "id7:L23", "layer": 23, "role": "process",  "column_type": "identity"},
    {"id": "id7:L5",  "layer": 5,  "role": "output",   "column_type": "identity"},
    {"id": "id7:L6",  "layer": 6,  "role": "feedback", "column_type": "identity"},

    {"_comment": "=== INHIBITORS ==="},
    {"id": "temporal_inhibitor", "role": "inhibitor", "description": "Competition between temporal columns."},
    {"id": "identity_inhibitor", "role": "inhibitor", "description": "Competition between identity columns. Forces specialization — only the most responsive column wins for each token."}
  ],

  "edges": [
    {"_comment": "=== TEMPORAL COLUMNS (same as before) ==="},

    {"_comment": "tc_fast: very low self-loop (0.1) — transient/onset"},
    {"source": "tc_fast:L4",  "target": "tc_fast:L23", "type": "temporal", "weight": 1.0},
    {"source": "tc_fast:L23", "target": "tc_fast:L5",  "type": "temporal", "weight": 1.0},
    {"source": "tc_fast:L5",  "target": "tc_fast:L6",  "type": "temporal", "weight": 1.0},
    {"source": "tc_fast:L6",  "target": "tc_fast:L4",  "type": "temporal", "weight": 0.5},
    {"source": "tc_fast:L23", "target": "tc_fast:L23", "type": "temporal", "weight": 0.1},

    {"_comment": "tc_mid: medium self-loop (0.4) — transitions"},
    {"source": "tc_mid:L4",  "target": "tc_mid:L23", "type": "temporal", "weight": 1.0},
    {"source": "tc_mid:L23", "target": "tc_mid:L5",  "type": "temporal", "weight": 1.0},
    {"source": "tc_mid:L5",  "target": "tc_mid:L6",  "type": "temporal", "weight": 1.0},
    {"source": "tc_mid:L6",  "target": "tc_mid:L4",  "type": "temporal", "weight": 0.5},
    {"source": "tc_mid:L23", "target": "tc_mid:L23", "type": "temporal", "weight": 0.4},

    {"_comment": "tc_slow: high self-loop (0.8) — sustained"},
    {"source": "tc_slow:L4",  "target": "tc_slow:L23", "type": "temporal", "weight": 1.0},
    {"source": "tc_slow:L23", "target": "tc_slow:L5",  "type": "temporal", "weight": 1.0},
    {"source": "tc_slow:L5",  "target": "tc_slow:L6",  "type": "temporal", "weight": 1.0},
    {"source": "tc_slow:L6",  "target": "tc_slow:L4",  "type": "temporal", "weight": 0.5},
    {"source": "tc_slow:L23", "target": "tc_slow:L23", "type": "temporal", "weight": 0.8},

    {"_comment": "Temporal hierarchy feedforward + feedback"},
    {"source": "tc_fast:L23", "target": "tc_mid:L4",  "type": "temporal", "weight": 0.5},
    {"source": "tc_mid:L23",  "target": "tc_slow:L4", "type": "temporal", "weight": 0.5},
    {"source": "tc_slow:L5",  "target": "tc_mid:L23",  "type": "temporal", "weight": 0.3},
    {"source": "tc_mid:L5",   "target": "tc_fast:L23", "type": "temporal", "weight": 0.3},

    {"_comment": "Mild forward suppression"},
    {"source": "tc_fast:L5", "target": "tc_slow:L23", "type": "temporal", "weight": -0.08},

    {"_comment": "Temporal column lateral inhibition"},
    {"source": "tc_fast:L23", "target": "temporal_inhibitor", "type": "temporal", "weight": 0.15},
    {"source": "tc_mid:L23",  "target": "temporal_inhibitor", "type": "temporal", "weight": 0.15},
    {"source": "tc_slow:L23", "target": "temporal_inhibitor", "type": "temporal", "weight": 0.15},
    {"source": "temporal_inhibitor", "target": "tc_fast:L23", "type": "spatial", "weight": -0.2},
    {"source": "temporal_inhibitor", "target": "tc_mid:L23",  "type": "spatial", "weight": -0.2},
    {"source": "temporal_inhibitor", "target": "tc_slow:L23", "type": "spatial", "weight": -0.2},

    {"_comment": "=== IDENTITY COLUMNS (standard cortical column wiring) ==="},
    {"_comment": "All 8 identity columns have the same internal structure."},
    {"_comment": "Self-loop 0.6 — moderate persistence (between fast and slow temporal)."},
    {"_comment": "Specialization comes from LEARNED input weights, not innate structure."},

    {"source": "id0:L4", "target": "id0:L23", "type": "temporal", "weight": 1.0},
    {"source": "id0:L23", "target": "id0:L5", "type": "temporal", "weight": 1.0},
    {"source": "id0:L5", "target": "id0:L6", "type": "temporal", "weight": 1.0},
    {"source": "id0:L6", "target": "id0:L4", "type": "temporal", "weight": 0.5},
    {"source": "id0:L23", "target": "id0:L23", "type": "temporal", "weight": 0.6},

    {"source": "id1:L4", "target": "id1:L23", "type": "temporal", "weight": 1.0},
    {"source": "id1:L23", "target": "id1:L5", "type": "temporal", "weight": 1.0},
    {"source": "id1:L5", "target": "id1:L6", "type": "temporal", "weight": 1.0},
    {"source": "id1:L6", "target": "id1:L4", "type": "temporal", "weight": 0.5},
    {"source": "id1:L23", "target": "id1:L23", "type": "temporal", "weight": 0.6},

    {"source": "id2:L4", "target": "id2:L23", "type": "temporal", "weight": 1.0},
    {"source": "id2:L23", "target": "id2:L5", "type": "temporal", "weight": 1.0},
    {"source": "id2:L5", "target": "id2:L6", "type": "temporal", "weight": 1.0},
    {"source": "id2:L6", "target": "id2:L4", "type": "temporal", "weight": 0.5},
    {"source": "id2:L23", "target": "id2:L23", "type": "temporal", "weight": 0.6},

    {"source": "id3:L4", "target": "id3:L23", "type": "temporal", "weight": 1.0},
    {"source": "id3:L23", "target": "id3:L5", "type": "temporal", "weight": 1.0},
    {"source": "id3:L5", "target": "id3:L6", "type": "temporal", "weight": 1.0},
    {"source": "id3:L6", "target": "id3:L4", "type": "temporal", "weight": 0.5},
    {"source": "id3:L23", "target": "id3:L23", "type": "temporal", "weight": 0.6},

    {"source": "id4:L4", "target": "id4:L23", "type": "temporal", "weight": 1.0},
    {"source": "id4:L23", "target": "id4:L5", "type": "temporal", "weight": 1.0},
    {"source": "id4:L5", "target": "id4:L6", "type": "temporal", "weight": 1.0},
    {"source": "id4:L6", "target": "id4:L4", "type": "temporal", "weight": 0.5},
    {"source": "id4:L23", "target": "id4:L23", "type": "temporal", "weight": 0.6},

    {"source": "id5:L4", "target": "id5:L23", "type": "temporal", "weight": 1.0},
    {"source": "id5:L23", "target": "id5:L5", "type": "temporal", "weight": 1.0},
    {"source": "id5:L5", "target": "id5:L6", "type": "temporal", "weight": 1.0},
