.vscode/

# Logs and checkpoints
logs/
checkpoints/
*.pt
*.pth
*.ckpt

# Data (too large for git)
data/recordings/
data/text_corpus/
data/rendered_text/

# OS files
.DS_Store
Thumbs.db

# Environment variables
.env

# Temporary files
*.tmp
*.temp